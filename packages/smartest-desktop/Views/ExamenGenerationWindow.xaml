<Window x:Class="smartest_desktop.Views.ExamenGenerationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:smartest_desktop.ViewModels"
        Title="SmarTest — Créer un examen"
        Height="720" Width="1280"
        MinHeight="600" MinWidth="960"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#fafbfd"
        FontFamily="Segoe UI">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Views/Styles/StylesGlobal.xaml"/>
            </ResourceDictionary.MergedDictionaries>

        <Style x:Key="CounterBtn" TargetType="Border">
            <Setter Property="Width" Value="25"/>
            <Setter Property="Height" Value="25"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="#eef3fd"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#e0e8fc"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DiffBtn" TargetType="Border">
            <Setter Property="CornerRadius" Value="9"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="108"/>
            <Setter Property="Background" Value="#f8fafc"/>
            <Setter Property="BorderBrush" Value="#e2e8f4"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="#fafbfd">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="White" Padding="14,10" Margin="0,0,0,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" ShadowDepth="1" Direction="270"
                                  Opacity="0.04" Color="#0f1e3d"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="28" Height="28" CornerRadius="7"
                        Background="#eef3fd" Cursor="Hand" Margin="0,0,8,0"
                        BorderBrush="#d0ddf5" BorderThickness="1">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding AnnulerCommand}"/>
                    </Border.InputBindings>
                    <TextBlock Text="&#xE72B;" FontSize="15" FontFamily="Segoe MDL2 Assets"
                               Foreground="#0f1e3d"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Nouvel examen" FontSize="20" FontWeight="700" Foreground="#0f1e3d"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENU -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══ COLONNE GAUCHE — Configuration ══ -->
            <Border Grid.Column="0" Background="#f5f7fa"
                    BorderBrush="#e8ecf5" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="24,26,24,28">

                        <TextBlock Text="Paramètres"
                                   FontSize="18" FontWeight="700" Foreground="#0f1e3d" Margin="0,0,0,24"/>

                        <!-- Titre -->
                        <TextBlock Text="TITRE DE L'EXAMEN" FontSize="10" FontWeight="700"
                                   Foreground="#9CA3AF" Margin="0,0,0,8"/>
                        <Border Background="White" CornerRadius="10" BorderBrush="#e2e8f4"
                                BorderThickness="1" Padding="14,12" Margin="0,0,0,24">
                            <TextBox Text="{Binding TitreExamen, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0" Background="Transparent"
                                     FontSize="12" Foreground="#0f1e3d"
                                     VerticalAlignment="Center" CaretBrush="#1A1A1A"/>
                        </Border>

                        <!-- Durée -->
                        <TextBlock Text="DURÉE (MINUTES)" FontSize="10" FontWeight="700"
                                   Foreground="#9CA3AF" Margin="0,0,0,8"/>
                        <ComboBox ItemsSource="{Binding DureesDisponibles}"
                                  SelectedItem="{Binding Duree}"
                                  Background="White" BorderBrush="#e2e8f4" BorderThickness="1"
                                  Padding="12,10" FontSize="13" Height="44"
                                  Margin="0,0,0,24"/>

                        <!-- Difficulté -->
                        <TextBlock Text="NIVEAU DE DIFFICULTÉ" FontSize="10" FontWeight="700"
                                   Foreground="#9CA3AF" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,28">

                            <Border Margin="0,0,8,0">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding SetDifficulteCommand}"
                                                  CommandParameter="Facile"/>
                                </Border.InputBindings>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource DiffBtn}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Difficulte}" Value="Facile">
                                                <Setter Property="Background" Value="#F0FDF4"/>
                                                <Setter Property="BorderBrush" Value="#86EFAC"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel HorizontalAlignment="Center">
                                    <Ellipse Width="12" Height="12" Fill="#22c55e" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Facile" FontSize="11" FontWeight="600"
                                               Foreground="#16A34A" HorizontalAlignment="Center"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Margin="0,0,8,0">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding SetDifficulteCommand}"
                                                  CommandParameter="Moyen"/>
                                </Border.InputBindings>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource DiffBtn}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Difficulte}" Value="Moyen">
                                                <Setter Property="Background" Value="#FFFBEB"/>
                                                <Setter Property="BorderBrush" Value="#FCD34D"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel HorizontalAlignment="Center">
                                    <Ellipse Width="12" Height="12" Fill="#f59e0b" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Moyen" FontSize="11" FontWeight="600"
                                               Foreground="#D97706" HorizontalAlignment="Center"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border>
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding SetDifficulteCommand}"
                                                  CommandParameter="Difficile"/>
                                </Border.InputBindings>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource DiffBtn}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Difficulte}" Value="Difficile">
                                                <Setter Property="Background" Value="#FFF1F2"/>
                                                <Setter Property="BorderBrush" Value="#FCA5A5"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel HorizontalAlignment="Center">
                                    <Ellipse Width="12" Height="12" Fill="#dc2626" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Difficile" FontSize="11" FontWeight="600"
                                               Foreground="#DC2626" HorizontalAlignment="Center"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Types de questions -->
                        <TextBlock Text="TYPES DE QUESTIONS" FontSize="10" FontWeight="700"
                                   Foreground="#9CA3AF" Margin="0,0,0,12"/>

                        <!-- QCM -->
                        <Border Background="White" CornerRadius="10" BorderBrush="#e2e8f4"
                                BorderThickness="1" Padding="16,12" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Choix multiple (QCM)"
                                           FontSize="13" FontWeight="600" Foreground="#0f1e3d"
                                           VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Style="{StaticResource CounterBtn}">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick" Command="{Binding DecrQCMCommand}"/>
                                        </Border.InputBindings>
                                        <TextBlock Text="−" FontSize="16" FontWeight="700" Foreground="#6B6B6B"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{Binding NbQCM}" FontSize="16" FontWeight="700"
                                               Foreground="#0f1e3d" Width="36"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               TextAlignment="Center"/>
                                    <Border Style="{StaticResource CounterBtn}">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick" Command="{Binding IncrQCMCommand}"/>
                                        </Border.InputBindings>
                                        <TextBlock Text="+" FontSize="16" FontWeight="700" Foreground="#6B6B6B"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- CHECKBOX -->
                        <Border Background="White" CornerRadius="10" BorderBrush="#e2e8f4"
                                BorderThickness="1" Padding="16,12" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Cases à cocher"
                                           FontSize="13" FontWeight="600" Foreground="#0f1e3d"
                                           VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Style="{StaticResource CounterBtn}">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick" Command="{Binding DecrCheckboxCommand}"/>
                                        </Border.InputBindings>
                                        <TextBlock Text="−" FontSize="16" FontWeight="700" Foreground="#6B6B6B"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{Binding NbCheckbox}" FontSize="16" FontWeight="700"
                                               Foreground="#0f1e3d" Width="36"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               TextAlignment="Center"/>
                                    <Border Style="{StaticResource CounterBtn}">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick" Command="{Binding IncrCheckboxCommand}"/>
                                        </Border.InputBindings>
                                        <TextBlock Text="+" FontSize="16" FontWeight="700" Foreground="#6B6B6B"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- RÉDACTION -->
                        <Border Background="White" CornerRadius="10" BorderBrush="#e2e8f4"
                                BorderThickness="1" Padding="16,12" Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Rédaction"
                                           FontSize="13" FontWeight="600" Foreground="#0f1e3d"
                                           VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Style="{StaticResource CounterBtn}">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick" Command="{Binding DecrRedactionCommand}"/>
                                        </Border.InputBindings>
                                        <TextBlock Text="−" FontSize="16" FontWeight="700" Foreground="#6B6B6B"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{Binding NbRedaction}" FontSize="16" FontWeight="700"
                                               Foreground="#0f1e3d" Width="36"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               TextAlignment="Center"/>
                                    <Border Style="{StaticResource CounterBtn}">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick" Command="{Binding IncrRedactionCommand}"/>
                                        </Border.InputBindings>
                                        <TextBlock Text="+" FontSize="16" FontWeight="700" Foreground="#6B6B6B"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Total -->
                        <Border Background="#eef3fd" CornerRadius="12"
                                BorderBrush="#cfe0fc" BorderThickness="1"
                                Padding="12,15" Margin="0,0,0,28">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Total de questions"
                                           FontSize="13" FontWeight="600" Foreground="#0f1e3d"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding TotalQuestions}"
                                           FontSize="17" FontWeight="700" Foreground="#4f8ef7"/>
                            </Grid>
                        </Border>

                        <!-- Messages de statut -->
                        <Border Background="#F0FDF4" CornerRadius="10" Padding="16,12"
                                Margin="0,0,0,12"
                                Visibility="{Binding HasStatus, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding StatusMessage}"
                                       FontSize="12" Foreground="#166534"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <Border Background="#FEF2F2" CornerRadius="10" Padding="16,12"
                                Margin="0,0,0,12"
                                Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding ErrorMessage}"
                                       FontSize="12" Foreground="#991B1B"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <!-- Bouton Générer -->
                        <Border CornerRadius="12" Padding="0,16" Cursor="Hand"
                                Visibility="{Binding IsNotGenerating, Converter={StaticResource BoolToVis}}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#0f1e3d"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1a2e5a"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding HasCours}" Value="False">
                                            <Setter Property="Background" Value="#B2C2DB"/>
                                            <Setter Property="Cursor" Value="Arrow"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding GenererCommand}"/>
                            </Border.InputBindings>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE99A;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           Foreground="White" Margin="0,0,5,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Générer l'examen"
                                           FontSize="14" FontWeight="600" Foreground="White"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Bouton Annuler génération -->
                        <Border CornerRadius="12" Padding="0,16" Cursor="Hand"
                                Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1"
                                Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVis}}">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding AnnulerGenerationCommand}"/>
                            </Border.InputBindings>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="#DC2626" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Annuler la génération"
                                           FontSize="13" FontWeight="600" Foreground="#DC2626"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ══ COLONNE DROITE — Import + cours (aligné quiz) ══ -->
            <Grid Grid.Column="1" Background="#fafbfd">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="28,22,28,18" Background="#fafbfd"
                        BorderBrush="#e8ecf5" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Cours importés" FontSize="17" FontWeight="700" Foreground="#0f1e3d"/>
                            <TextBlock Text="Import multiple possible · texte modifiable ci-dessous."
                                       FontSize="12" Foreground="#8899b8" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" CornerRadius="10" Cursor="Hand" Padding="16,10" VerticalAlignment="Center">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding ImporterFichierCommand}"/>
                            </Border.InputBindings>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#0f1e3d"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1a2e5a"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding IsImporting}" Value="True">
                                            <Setter Property="Background" Value="#6B7280"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontSize="12" FontWeight="600" Foreground="White">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Importer des cours"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsImporting}" Value="True">
                                                    <Setter Property="Text" Value="Import en cours..."/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding HasCours}" Value="True">
                                                    <Setter Property="Text" Value="Ajouter des cours"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">

                    <!-- État vide -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,40">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasCours}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Border Width="320" Height="220" CornerRadius="16"
                                BorderBrush="#e2e8f4" BorderThickness="2"
                                Background="White" Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding ImporterFichierCommand}"/>
                            </Border.InputBindings>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="#4f8ef7"/>
                                            <Setter Property="Background" Value="#f8fbff"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="44"
                                           Foreground="#4f8ef7" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                                <TextBlock Text="Importer des cours"
                                           FontSize="14" FontWeight="600" Foreground="#0f1e3d"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="PDF · DOCX · TXT"
                                           FontSize="12" Foreground="#ABABAB"
                                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Cours importé -->
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasCours}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Margin="20,16,20,0" CornerRadius="12"
                                Background="#eef3fd" BorderBrush="#cfe0fc" BorderThickness="1" Padding="14,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0">
                                    <ItemsControl ItemsSource="{Binding FichiersImportes}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,8,8" Padding="10,6" CornerRadius="8"
                                                        Background="White" BorderBrush="#cfe0fc" BorderThickness="1">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Titre}" FontWeight="600" FontSize="12"
                                                                   Foreground="#0f1e3d"/>
                                                        <Border CornerRadius="4" Padding="4,1" Margin="8,0,0,0"
                                                                Background="#dfe8fb" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding TypeExtension}" FontSize="10"
                                                                       FontWeight="700" Foreground="#0f1e3d"/>
                                                        </Border>
                                                        <Border Width="20" Height="20" CornerRadius="6"
                                                                Background="#FEE2E2" Cursor="Hand"
                                                                Margin="8,0,0,0" VerticalAlignment="Center">
                                                            <Border.InputBindings>
                                                                <MouseBinding MouseAction="LeftClick"
                                                                              Command="{Binding DataContext.SupprimerFichierImporteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                              CommandParameter="{Binding}"/>
                                                            </Border.InputBindings>
                                                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                                                       FontSize="9" Foreground="#DC2626"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                                <TextBlock Grid.Row="1" Text="{Binding NombreCaracteres}" FontSize="11"
                                           Foreground="#6b7a99" Margin="0,8,0,0"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Margin="20,12,20,20" CornerRadius="12"
                                Background="White" BorderBrush="#e2e8f4" BorderThickness="1.5">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Padding="14,10" BorderBrush="#e2e8f4" BorderThickness="0,0,0,1"
                                        Background="#fafbfd">
                                    <TextBlock Text="Texte extrait (modifiable)"
                                               FontSize="11" FontWeight="600" Foreground="#6b7a99"/>
                                </Border>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Padding="14,12" MinHeight="240">
                                    <TextBox Text="{Binding ContenuCours, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="12" Foreground="#374151"
                                             BorderThickness="0" Background="Transparent"
                                             TextWrapping="Wrap" AcceptsReturn="True"
                                             FontFamily="Consolas"
                                             CaretBrush="#4f8ef7"/>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>

                </Grid>
            </Grid>

        </Grid>

        <Border Grid.Row="2" Background="White" BorderBrush="#e2e8f4" BorderThickness="0,1,0,0" Padding="18,14">
            <TextBlock Text="SmarTest — ENSA Oujda · Génie Informatique · 2025–2026"
                       FontSize="11" Foreground="#aab4cc"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

    </Grid>
</Window>
