<Window x:Class="smartest_desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmarTest — Connexion Professeur"
        Height="600" Width="900"
        MinHeight="500" MinWidth="700"
        ResizeMode="CanResize"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#f0f3f9">

	<Window.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary Source="/Views/Styles/AuthStyles.xaml"/>
			</ResourceDictionary.MergedDictionaries>
		</ResourceDictionary>
	</Window.Resources>

	<Grid Background="#f0f3f9">

		<!-- Glow décoratif -->
		<Ellipse Width="400" Height="400" HorizontalAlignment="Right"
                 VerticalAlignment="Top" Margin="0,-150,-150,0"
                 Fill="#084f8ef7" Opacity="0.06"/>

		<Border Style="{StaticResource MainCard}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
			<Border.Effect>
				<DropShadowEffect Color="#000000" Opacity="0.07"
                                  BlurRadius="24" ShadowDepth="3"/>
			</Border.Effect>

			<StackPanel>

				<!-- Brand -->
				<TextBlock Text="SmarTest" Style="{StaticResource BrandTitle}"/>
				<TextBlock Text="PLATEFORME D'ÉVALUATION" Style="{StaticResource BrandSub}"/>

				<!-- Badge + Titre -->

				<TextBlock Text="Bon retour !" FontFamily="Georgia" FontSize="22"
                           Foreground="#0f1e3d" HorizontalAlignment="Center" Margin="0,0,0,0"/>
				<Border Style="{StaticResource AccentLine}"/>

				<!-- Erreur -->
				<Border Style="{StaticResource AlertError}"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
					<TextBlock Text="{Binding ErrorMessage}" Foreground="#791f1f"
                               FontSize="12" TextWrapping="Wrap"/>
				</Border>

				<!-- Email -->
				<TextBlock Text="Email" Style="{StaticResource FieldLabel}"/>
				<TextBox Style="{StaticResource InputBox}"
                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12"/>

				<!-- Mot de passe -->
				<TextBlock Text="Mot de passe" Style="{StaticResource FieldLabel}"/>
				<PasswordBox x:Name="PasswordBox"
                             Style="{StaticResource InputPassword}"
                             PasswordChanged="PasswordBox_PasswordChanged"
                             Margin="0,0,0,6"/>

				<!-- Mot de passe oublié -->
				<TextBlock HorizontalAlignment="Right" Margin="0,0,0,18">
					<Hyperlink Command="{Binding ForgotPasswordCommand}"
                               Foreground="#1a2e5a" TextDecorations="None">
						Mot de passe oublié ?
					</Hyperlink>
				</TextBlock>

				<!-- Bouton Se connecter -->
				<Button Style="{StaticResource PrimaryBtn}"
                        Command="{Binding LoginCommand}"
                        Margin="0,0,0,12">
					<TextBlock>
						<TextBlock.Style>
							<Style TargetType="TextBlock">
								<Setter Property="Text" Value="Se connecter"/>
								<Style.Triggers>
									<DataTrigger Binding="{Binding IsLoading}" Value="True">
										<Setter Property="Text" Value="Connexion en cours..."/>
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</TextBlock.Style>
					</TextBlock>
				</Button>

				<!-- Séparateur -->
				<Grid Margin="0,0,0,12">
					<Separator/>
					<TextBlock Text="ou" Background="White" Foreground="#8899b8"
                               FontSize="11" HorizontalAlignment="Center" Padding="10,0"/>
				</Grid>

				<!-- Bouton Créer un compte -->
				<Button Style="{StaticResource SecondaryBtn}"
                        Command="{Binding RegisterCommand}">
					<TextBlock Text="Créer un compte professeur"/>
				</Button>

				<!-- Footer -->
				<TextBlock Text="SmarTest — ENSA Oujda" Style="{StaticResource FooterText}"/>

			</StackPanel>
		</Border>
	</Grid>
</Window>
