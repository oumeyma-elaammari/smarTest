<Window x:Class="smartest_desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:smartest_desktop.ViewModels"
        Title="SmarTest — Connexion Professeur"
        Height="600" Width="900"
        MinHeight="500" MinWidth="700"
        ResizeMode="CanResize"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6">

    <Window.DataContext>
        <vm:LoginViewModel />
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <!-- ✅ Grid centré -->
    <Grid Background="#F3F4F6">
        <Border Background="White"
                CornerRadius="12"
                Padding="40"
                Width="480"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.08"
                                  BlurRadius="20" ShadowDepth="4"/>
            </Border.Effect>

            <StackPanel>

                <!-- Header -->
                <TextBlock Text="SmarTest"
                           FontSize="26" FontWeight="Bold"
                           Foreground="#1a2e5a"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4"/>
                <TextBlock Text="Espace Professeur"
                           FontSize="13" Foreground="#6B7280"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,28"/>

                <!-- Erreur -->
                <Border Background="#FEF2F2"
                        BorderBrush="#FECACA"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12,8"
                        Margin="0,0,0,14"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#DC2626"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Email -->
                <TextBlock Text="Email"
                           FontWeight="SemiBold" FontSize="13"
                           Margin="0,0,0,4"/>
                <TextBox Height="40" Padding="10,0"
                         FontSize="13"
                         BorderBrush="#D1D5DB" BorderThickness="1"
                         VerticalContentAlignment="Center"
                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,14"/>

                <!-- Password -->
                <TextBlock Text="Mot de passe"
                           FontWeight="SemiBold" FontSize="13"
                           Margin="0,0,0,4"/>
                <PasswordBox x:Name="PasswordBox"
                             Height="40" Padding="10,0"
                             FontSize="13"
                             BorderBrush="#D1D5DB" BorderThickness="1"
                             VerticalContentAlignment="Center"
                             PasswordChanged="PasswordBox_PasswordChanged"
                             Margin="0,0,0,6"/>

                <!-- Mot de passe oublié -->
                <TextBlock HorizontalAlignment="Right" Margin="0,0,0,20">
                    <Hyperlink Command="{Binding ForgotPasswordCommand}"
                               Foreground="#1a2e5a"
                               TextDecorations="None">
                        Mot de passe oublié ?
                    </Hyperlink>
                </TextBlock>

                <!-- Bouton Login -->
                <Button Height="42" Foreground="White"
                        FontWeight="SemiBold" FontSize="13"
                        BorderThickness="0" Cursor="Hand"
                        Command="{Binding LoginCommand}"
                        Margin="0,0,0,14">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#1a2e5a"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#15244a"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.6"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <TextBlock>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Se connecter"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                        <Setter Property="Text" Value="Connexion en cours..."/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>

                <!-- Séparateur -->
                <Grid Margin="0,0,0,14">
                    <Separator/>
                    <TextBlock Text="ou" Background="White"
                               Foreground="#9CA3AF" FontSize="12"
                               HorizontalAlignment="Center"
                               Padding="8,0"/>
                </Grid>

                <!-- Bouton S'inscrire -->
                <Button Height="42" Foreground="#1a2e5a"
                        FontWeight="SemiBold" FontSize="13"
                        Cursor="Hand"
                        Command="{Binding RegisterCommand}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6"
                                                BorderBrush="#D1D5DB"
                                                BorderThickness="1">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#F9FAFB"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="Créer un compte professeur"/>
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</Window>
