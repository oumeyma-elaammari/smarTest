<Window x:Class="smartest_desktop.Views.ExamenResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmarTest — Révision de l'examen"
        Height="720" Width="1200"
        MinHeight="600" MinWidth="1000"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#F8F8F6"
        FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="OptionRow" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderBrush" Value="#E8E7E3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="ActionBtn" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════ HEADER ═══════════════ -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="#E8E7E3" BorderThickness="0,0,0,1" Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8"
                        Background="#F0EFE8" Cursor="Hand" Margin="0,0,16,0">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding RetourCommand}"/>
                    </Border.InputBindings>
                    <TextBlock Text="←" FontSize="18" FontWeight="300" Foreground="#1A1A1A"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding TitreExamen}"
                               FontSize="16" FontWeight="700" Foreground="#1A1A1A"/>
                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                        <TextBlock FontSize="11" Foreground="#ABABAB">
                            <Run Text="{Binding NombreQuestions, Mode=OneWay}"/>
                            <Run Text=" questions"/>
                        </TextBlock>
                        <TextBlock Text=" · " FontSize="11" Foreground="#ABABAB"/>
                        <TextBlock Text="{Binding Difficulte}" FontSize="11" Foreground="#ABABAB"/>
                        <TextBlock Text=" · " FontSize="11" Foreground="#ABABAB"/>
                        <TextBlock FontSize="11" Foreground="#ABABAB">
                            <Run Text="{Binding Duree, Mode=OneWay}"/>
                            <Run Text=" min"/>
                        </TextBlock>
                        <TextBlock Text=" · " FontSize="11" Foreground="#ABABAB"/>
                        <TextBlock Text="{Binding CoursSourceLabel}"
                                   FontSize="11" Foreground="#ABABAB"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Border CornerRadius="8" Padding="14,10" Cursor="Hand"
                            Margin="0,0,10,0" Background="#F0EFE8">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding RegenerarCommand}"/>
                        </Border.InputBindings>
                        <TextBlock Text="🔄 Regénérer" FontSize="12"
                                   FontWeight="600" Foreground="#6B6B6B"/>
                    </Border>
                    <Border CornerRadius="8" Padding="14,10" Cursor="Hand"
                            Background="#1A1A1A">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#1A1A1A"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#333333"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding ValiderExamenCommand}"/>
                        </Border.InputBindings>
                        <TextBlock Text="✅ Valider et sauvegarder"
                                   FontSize="12" FontWeight="600" Foreground="White"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Message succès -->
        <Border Grid.Row="0" VerticalAlignment="Bottom"
                Background="#DCFCE7" Padding="20,10"
                Visibility="{Binding HasSuccess, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding SuccessMessage}"
                       FontSize="13" FontWeight="600" Foreground="#166534"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- ═══════════════ CONTENU ═══════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══ LISTE DES QUESTIONS ══ -->
            <Border Grid.Column="0" Background="#FAFAF9"
                    BorderBrush="#E8E7E3" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="20,16" BorderBrush="#E8E7E3" BorderThickness="0,0,0,1">
                        <TextBlock Text="Questions générées"
                                   FontSize="14" FontWeight="700" Foreground="#1A1A1A"/>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Questions}" Margin="12,12,12,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,6" CornerRadius="10"
                                            Padding="14,12" Cursor="Hand" BorderThickness="1.5">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.SelectionnerCommand,
                                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                          CommandParameter="{Binding}"/>
                                        </Border.InputBindings>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="White"/>
                                                <Setter Property="BorderBrush" Value="#E8E7E3"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Background" Value="#F5F3FF"/>
                                                        <Setter Property="BorderBrush" Value="#7C3AED"/>
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="#A78BFA"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Numero}"
                                                           FontSize="12" FontWeight="700"
                                                           Foreground="#6B6B6B"
                                                           Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <Border CornerRadius="4" Padding="6,2">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="{Binding TypeBackground}"/>
                                                    </Border.Background>
                                                    <TextBlock Text="{Binding TypeLabel}"
                                                               FontSize="9" FontWeight="700">
                                                        <TextBlock.Foreground>
                                                            <SolidColorBrush Color="{Binding TypeColor}"/>
                                                        </TextBlock.Foreground>
                                                    </TextBlock>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding Enonce}"
                                                       FontSize="12" Foreground="#1A1A1A"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="42"
                                                       Margin="0,6,0,0"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ══ DÉTAIL DE LA QUESTION ══ -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <Grid Margin="36,32,36,32">

                    <!-- Placeholder si aucune question sélectionnée -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding NoQuestion, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="←" FontSize="40" Foreground="#E8E7E3"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Sélectionnez une question"
                                   FontSize="16" Foreground="#ABABAB"
                                   HorizontalAlignment="Center" Margin="0,12,0,0"/>
                        <TextBlock Text="pour afficher et modifier son contenu"
                                   FontSize="13" Foreground="#CACACA"
                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- Contenu si question sélectionnée -->
                    <StackPanel Visibility="{Binding HasQuestion, Converter={StaticResource BoolToVis}}">

                        <!-- En-tête de question -->
                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock FontSize="12" Foreground="#9CA3AF">
                                        <Run Text="Question"/>
                                        <Run Text="{Binding QuestionSelectionnee.Numero, Mode=OneWay}"/>
                                    </TextBlock>
                                    <Border CornerRadius="5" Padding="8,3"
                                            Margin="10,0,0,0"
                                            Background="{Binding QuestionSelectionnee.TypeBackground}">
                                        <TextBlock Text="{Binding QuestionSelectionnee.TypeLabel}"
                                                   FontSize="10" FontWeight="700"
                                                   Foreground="{Binding QuestionSelectionnee.TypeColor}"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <!-- Bouton Éditer -->
                                <Border CornerRadius="8" Padding="14,8" Cursor="Hand"
                                        Background="#F0EFE8" Margin="0,0,8,0"
                                        Visibility="{Binding QuestionSelectionnee.IsNotEditing, Converter={StaticResource BoolToVis}}">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding EditerCommand}"/>
                                    </Border.InputBindings>
                                    <TextBlock Text="✏ Modifier" FontSize="12"
                                               FontWeight="600" Foreground="#1A1A1A"/>
                                </Border>
                                <!-- Bouton Supprimer -->
                                <Border CornerRadius="8" Padding="14,8" Cursor="Hand"
                                        Background="#FEF2F2"
                                        Visibility="{Binding QuestionSelectionnee.IsNotEditing, Converter={StaticResource BoolToVis}}">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding SupprimerCommand}"
                                                      CommandParameter="{Binding QuestionSelectionnee}"/>
                                    </Border.InputBindings>
                                    <TextBlock Text="🗑 Supprimer" FontSize="12"
                                               FontWeight="600" Foreground="#DC2626"/>
                                </Border>
                                <!-- Bouton Sauvegarder édition -->
                                <Border CornerRadius="8" Padding="14,8" Cursor="Hand"
                                        Background="#1A1A1A" Margin="0,0,8,0"
                                        Visibility="{Binding QuestionSelectionnee.IsEditing, Converter={StaticResource BoolToVis}}">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding SauvegarderEditionCommand}"/>
                                    </Border.InputBindings>
                                    <TextBlock Text="💾 Sauvegarder" FontSize="12"
                                               FontWeight="600" Foreground="White"/>
                                </Border>
                                <!-- Bouton Annuler édition -->
                                <Border CornerRadius="8" Padding="14,8" Cursor="Hand"
                                        Background="#F0EFE8"
                                        Visibility="{Binding QuestionSelectionnee.IsEditing, Converter={StaticResource BoolToVis}}">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding AnnulerEditionCommand}"/>
                                    </Border.InputBindings>
                                    <TextBlock Text="✕ Annuler" FontSize="12"
                                               FontWeight="600" Foreground="#6B6B6B"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- Énoncé -->
                        <TextBlock Text="ÉNONCÉ" FontSize="10" FontWeight="700"
                                   Foreground="#9CA3AF" Margin="0,0,0,8"/>
                        <Border Background="White" CornerRadius="10"
                                BorderBrush="#E8E7E3" BorderThickness="1"
                                Padding="16,14" Margin="0,0,0,24">
                            <TextBox Text="{Binding QuestionSelectionnee.Enonce,
                                                    UpdateSourceTrigger=PropertyChanged}"
                                     IsReadOnly="{Binding QuestionSelectionnee.IsNotEditing}"
                                     BorderThickness="0" Background="Transparent"
                                     FontSize="14" Foreground="#1A1A1A" TextWrapping="Wrap"
                                     AcceptsReturn="True" MinHeight="60"/>
                        </Border>

                        <!-- ── Options QCM / CHECKBOX / IMAGE ── -->
                        <StackPanel Visibility="{Binding QuestionSelectionnee.HasOptions,
                                                  Converter={StaticResource BoolToVis}}">

                            <TextBlock Text="OPTIONS" FontSize="10" FontWeight="700"
                                       Foreground="#9CA3AF" Margin="0,0,0,10"/>

                            <!-- Option A -->
                            <Border Style="{StaticResource OptionRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="28" Height="28" CornerRadius="7"
                                            Background="#F5F4F0" Margin="0,0,12,0"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="A" FontSize="12" FontWeight="700"
                                                   Foreground="#6B6B6B"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding QuestionSelectionnee.OptionA,
                                                            UpdateSourceTrigger=PropertyChanged}"
                                             IsReadOnly="{Binding QuestionSelectionnee.IsNotEditing}"
                                             BorderThickness="0" Background="Transparent"
                                             FontSize="13" Foreground="#1A1A1A"
                                             VerticalAlignment="Center"/>
                                    <!-- QCM/IMAGE : radio -->
                                    <Border Grid.Column="2" Width="20" Height="20" CornerRadius="10"
                                            Margin="12,0,0,0" VerticalAlignment="Center"
                                            Visibility="{Binding QuestionSelectionnee.IsQCM, Converter={StaticResource BoolToVis}}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush" Value="#E8E7E3"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                                <Setter Property="Background" Value="White"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding QuestionSelectionnee.ReponseCorrecte}" Value="A">
                                                        <Setter Property="Background" Value="#1A1A1A"/>
                                                        <Setter Property="BorderBrush" Value="#1A1A1A"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <!-- CHECKBOX : checkbox -->
                                    <CheckBox Grid.Column="2" Margin="12,0,0,0"
                                              IsChecked="{Binding QuestionSelectionnee.OptionACorrecte}"
                                              IsEnabled="{Binding QuestionSelectionnee.IsEditing}"
                                              Visibility="{Binding QuestionSelectionnee.IsCheckbox,
                                                           Converter={StaticResource BoolToVis}}"/>
                                </Grid>
                            </Border>

                            <!-- Option B -->
                            <Border Style="{StaticResource OptionRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="28" Height="28" CornerRadius="7"
                                            Background="#F5F4F0" Margin="0,0,12,0"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="B" FontSize="12" FontWeight="700"
                                                   Foreground="#6B6B6B"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding QuestionSelectionnee.OptionB,
                                                            UpdateSourceTrigger=PropertyChanged}"
                                             IsReadOnly="{Binding QuestionSelectionnee.IsNotEditing}"
                                             BorderThickness="0" Background="Transparent"
                                             FontSize="13" Foreground="#1A1A1A"
                                             VerticalAlignment="Center"/>
                                    <Border Grid.Column="2" Width="20" Height="20" CornerRadius="10"
                                            Margin="12,0,0,0" VerticalAlignment="Center"
                                            Visibility="{Binding QuestionSelectionnee.IsQCM, Converter={StaticResource BoolToVis}}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush" Value="#E8E7E3"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                                <Setter Property="Background" Value="White"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding QuestionSelectionnee.ReponseCorrecte}" Value="B">
                                                        <Setter Property="Background" Value="#1A1A1A"/>
                                                        <Setter Property="BorderBrush" Value="#1A1A1A"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <CheckBox Grid.Column="2" Margin="12,0,0,0"
                                              IsChecked="{Binding QuestionSelectionnee.OptionBCorrecte}"
                                              IsEnabled="{Binding QuestionSelectionnee.IsEditing}"
                                              Visibility="{Binding QuestionSelectionnee.IsCheckbox,
                                                           Converter={StaticResource BoolToVis}}"/>
                                </Grid>
                            </Border>

                            <!-- Option C -->
                            <Border Style="{StaticResource OptionRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="28" Height="28" CornerRadius="7"
                                            Background="#F5F4F0" Margin="0,0,12,0"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="C" FontSize="12" FontWeight="700"
                                                   Foreground="#6B6B6B"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding QuestionSelectionnee.OptionC,
                                                            UpdateSourceTrigger=PropertyChanged}"
                                             IsReadOnly="{Binding QuestionSelectionnee.IsNotEditing}"
                                             BorderThickness="0" Background="Transparent"
                                             FontSize="13" Foreground="#1A1A1A"
                                             VerticalAlignment="Center"/>
                                    <Border Grid.Column="2" Width="20" Height="20" CornerRadius="10"
                                            Margin="12,0,0,0" VerticalAlignment="Center"
                                            Visibility="{Binding QuestionSelectionnee.IsQCM, Converter={StaticResource BoolToVis}}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush" Value="#E8E7E3"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                                <Setter Property="Background" Value="White"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding QuestionSelectionnee.ReponseCorrecte}" Value="C">
                                                        <Setter Property="Background" Value="#1A1A1A"/>
                                                        <Setter Property="BorderBrush" Value="#1A1A1A"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <CheckBox Grid.Column="2" Margin="12,0,0,0"
                                              IsChecked="{Binding QuestionSelectionnee.OptionCCorrecte}"
                                              IsEnabled="{Binding QuestionSelectionnee.IsEditing}"
                                              Visibility="{Binding QuestionSelectionnee.IsCheckbox,
                                                           Converter={StaticResource BoolToVis}}"/>
                                </Grid>
                            </Border>

                            <!-- Option D -->
                            <Border Style="{StaticResource OptionRow}" Margin="0,0,0,24">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="28" Height="28" CornerRadius="7"
                                            Background="#F5F4F0" Margin="0,0,12,0"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="D" FontSize="12" FontWeight="700"
                                                   Foreground="#6B6B6B"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding QuestionSelectionnee.OptionD,
                                                            UpdateSourceTrigger=PropertyChanged}"
                                             IsReadOnly="{Binding QuestionSelectionnee.IsNotEditing}"
                                             BorderThickness="0" Background="Transparent"
                                             FontSize="13" Foreground="#1A1A1A"
                                             VerticalAlignment="Center"/>
                                    <Border Grid.Column="2" Width="20" Height="20" CornerRadius="10"
                                            Margin="12,0,0,0" VerticalAlignment="Center"
                                            Visibility="{Binding QuestionSelectionnee.IsQCM, Converter={StaticResource BoolToVis}}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush" Value="#E8E7E3"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                                <Setter Property="Background" Value="White"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding QuestionSelectionnee.ReponseCorrecte}" Value="D">
                                                        <Setter Property="Background" Value="#1A1A1A"/>
                                                        <Setter Property="BorderBrush" Value="#1A1A1A"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <CheckBox Grid.Column="2" Margin="12,0,0,0"
                                              IsChecked="{Binding QuestionSelectionnee.OptionDCorrecte}"
                                              IsEnabled="{Binding QuestionSelectionnee.IsEditing}"
                                              Visibility="{Binding QuestionSelectionnee.IsCheckbox,
                                                           Converter={StaticResource BoolToVis}}"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- ── Section IMAGE ── -->
                        <StackPanel Visibility="{Binding QuestionSelectionnee.IsImage,
                                                  Converter={StaticResource BoolToVis}}"
                                    Margin="0,0,0,24">
                            <TextBlock Text="IMAGE ASSOCIÉE" FontSize="10" FontWeight="700"
                                       Foreground="#9CA3AF" Margin="0,0,0,10"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border CornerRadius="8" Padding="14,10" Cursor="Hand"
                                        Background="#F0FDFA" BorderBrush="#99F6E4"
                                        BorderThickness="1" Margin="0,0,8,0">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding AttacherImageCommand}"/>
                                    </Border.InputBindings>
                                    <TextBlock Text="🖼 Attacher une image"
                                               FontSize="12" FontWeight="600" Foreground="#0F766E"/>
                                </Border>
                                <Border CornerRadius="8" Padding="14,10" Cursor="Hand"
                                        Background="#FEF2F2" BorderBrush="#FCA5A5"
                                        BorderThickness="1"
                                        Visibility="{Binding QuestionSelectionnee.HasImage,
                                                     Converter={StaticResource BoolToVis}}">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding SupprimerImageCommand}"/>
                                    </Border.InputBindings>
                                    <TextBlock Text="🗑 Supprimer l'image"
                                               FontSize="12" FontWeight="600" Foreground="#DC2626"/>
                                </Border>
                            </StackPanel>

                            <!-- Aperçu image -->
                            <Border CornerRadius="10" Background="White"
                                    BorderBrush="#E8E7E3" BorderThickness="1"
                                    Padding="12" MaxHeight="220"
                                    Visibility="{Binding QuestionSelectionnee.HasImage,
                                                 Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <TextBlock Text="{Binding QuestionSelectionnee.ImageNom}"
                                               FontSize="11" Foreground="#9CA3AF"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="[Aperçu image non disponible — l'image est stockée en Base64]"
                                               FontSize="12" Foreground="#ABABAB"
                                               FontStyle="Italic"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ── Section REDACTION ── -->
                        <StackPanel Visibility="{Binding QuestionSelectionnee.IsRedaction,
                                                  Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="RÉPONSE MODÈLE" FontSize="10" FontWeight="700"
                                       Foreground="#9CA3AF" Margin="0,0,0,8"/>
                            <Border Background="White" CornerRadius="10"
                                    BorderBrush="#E8E7E3" BorderThickness="1"
                                    Padding="16,14" Margin="0,0,0,24">
                                <TextBox Text="{Binding QuestionSelectionnee.ReponseModele,
                                                        UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="{Binding QuestionSelectionnee.IsNotEditing}"
                                         BorderThickness="0" Background="Transparent"
                                         FontSize="13" Foreground="#1A1A1A" TextWrapping="Wrap"
                                         AcceptsReturn="True" MinHeight="80"/>
                            </Border>
                        </StackPanel>

                        <!-- Explication -->
                        <TextBlock Text="EXPLICATION / CORRECTION"
                                   FontSize="10" FontWeight="700"
                                   Foreground="#9CA3AF" Margin="0,0,0,8"/>
                        <Border Background="#FFFBEB" CornerRadius="10"
                                BorderBrush="#FDE68A" BorderThickness="1"
                                Padding="16,14">
                            <TextBox Text="{Binding QuestionSelectionnee.Explication,
                                                    UpdateSourceTrigger=PropertyChanged}"
                                     IsReadOnly="{Binding QuestionSelectionnee.IsNotEditing}"
                                     BorderThickness="0" Background="Transparent"
                                     FontSize="13" Foreground="#92400E" TextWrapping="Wrap"
                                     AcceptsReturn="True" MinHeight="60"/>
                        </Border>

                    </StackPanel>
                </Grid>
            </ScrollViewer>

        </Grid>
    </Grid>
</Window>
