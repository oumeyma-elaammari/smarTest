<Window x:Class="smartest_desktop.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:smartest_desktop.ViewModels"
        Title="SmarTest"
        Height="720" Width="1080"
        MinHeight="600" MinWidth="860"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#F5F4F0"
        FontFamily="Segoe UI">

	<Window.DataContext>
		<vm:DashboardViewModel />
	</Window.DataContext>

	<Window.Resources>
		<Style x:Key="NavItem" TargetType="Border">
			<Setter Property="CornerRadius" Value="10"/>
			<Setter Property="Padding" Value="14,0"/>
			<Setter Property="Height" Value="42"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Background" Value="Transparent"/>
			<Style.Triggers>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="#EBEBEA"/>
				</Trigger>
			</Style.Triggers>
		</Style>
		<Style x:Key="Card" TargetType="Border">
			<Setter Property="Background" Value="White"/>
			<Setter Property="CornerRadius" Value="14"/>
			<Setter Property="BorderBrush" Value="#E8E7E3"/>
			<Setter Property="BorderThickness" Value="1"/>
		</Style>
		<BooleanToVisibilityConverter x:Key="BoolToVis"/>
	</Window.Resources>

	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="230"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>

		<!-- ══ SIDEBAR ══ -->
		<Border Grid.Column="0" Background="#FAFAF9" BorderBrush="#E8E7E3" BorderThickness="0,0,1,0">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>

				<!-- Logo -->
				<StackPanel Grid.Row="0" Margin="22,30,22,36">
					<StackPanel Orientation="Horizontal">
						<Border Width="8" Height="8" CornerRadius="4" Background="#1A1A1A"
                                VerticalAlignment="Center" Margin="0,0,8,0"/>
						<TextBlock FontSize="17" FontWeight="700" Foreground="#1A1A1A">
							<Run Text="Smar"/>
							<Run Text="Test" Foreground="#6B6B6B"/>
						</TextBlock>
					</StackPanel>
					<TextBlock Text="Espace professeur" FontSize="11" Foreground="#ABABAB" Margin="16,5,0,0"/>
				</StackPanel>

				<!-- Nav items -->
				<StackPanel Grid.Row="1" Margin="12,0">

					<!-- Tableau de bord — actif -->
					<Border CornerRadius="10" Height="42" Padding="14,0"
                            Background="#1A1A1A" Margin="0,1">
						<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
							<TextBlock Text="⊞" FontSize="14" Foreground="#FFFFFF" Margin="0,0,10,0"/>
							<TextBlock Text="Tableau de bord" FontSize="13"
                                       FontWeight="SemiBold" Foreground="#FFFFFF"/>
						</StackPanel>
					</Border>

					<!-- Mes cours -->
					<Border Style="{StaticResource NavItem}" Margin="0,1">
						<Border.InputBindings>
							<MouseBinding MouseAction="LeftClick" Command="{Binding OpenCoursCommand}"/>
						</Border.InputBindings>
						<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
							<TextBlock Text="▤" FontSize="14" Foreground="#6B6B6B" Margin="0,0,10,0"/>
							<TextBlock Text="Mes cours" FontSize="13" Foreground="#444444"/>
						</StackPanel>
					</Border>

					<!-- Quiz et examens — connecté à OpenQuizCommand -->
					<Border Style="{StaticResource NavItem}" Margin="0,1">
						<Border.InputBindings>
							<MouseBinding MouseAction="LeftClick" Command="{Binding OpenQuizCommand}"/>
						</Border.InputBindings>
						<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
							<TextBlock Text="✎" FontSize="14" Foreground="#6B6B6B" Margin="0,0,10,0"/>
							<TextBlock Text="Quiz et examens" FontSize="13" Foreground="#444444"/>
						</StackPanel>
					</Border>

					<!-- Sessions actives -->
					<Border Style="{StaticResource NavItem}" Margin="0,1">
						<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
							<TextBlock Text="◎" FontSize="14" Foreground="#6B6B6B" Margin="0,0,10,0"/>
							<TextBlock Text="Sessions actives" FontSize="13" Foreground="#444444"/>
						</StackPanel>
					</Border>

					<!-- Statistiques -->
					<Border Style="{StaticResource NavItem}" Margin="0,1">
						<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
							<TextBlock Text="▦" FontSize="14" Foreground="#6B6B6B" Margin="0,0,10,0"/>
							<TextBlock Text="Statistiques" FontSize="13" Foreground="#444444"/>
						</StackPanel>
					</Border>

					<!-- Paramètres -->
					<Border Style="{StaticResource NavItem}" Margin="0,1">
						<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
							<TextBlock Text="⚙" FontSize="13" Foreground="#6B6B6B" Margin="0,0,10,0"/>
							<TextBlock Text="Paramètres" FontSize="13" Foreground="#444444"/>
						</StackPanel>
					</Border>
				</StackPanel>

				<!-- User info + Déconnexion -->
				<StackPanel Grid.Row="2" Margin="12,0,12,24">
					<Border Background="#F0EFE8" CornerRadius="12" Padding="14,12" Margin="0,0,0,8">
						<StackPanel>
							<TextBlock Text="{Binding Nom}"   FontSize="13" FontWeight="600" Foreground="#1A1A1A"/>
							<TextBlock Text="{Binding Email}" FontSize="11" Foreground="#ABABAB" Margin="0,3,0,0"/>
						</StackPanel>
					</Border>
					<Border Style="{StaticResource NavItem}" Margin="0,1">
						<Border.InputBindings>
							<MouseBinding MouseAction="LeftClick" Command="{Binding LogoutCommand}"/>
						</Border.InputBindings>
						<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
							<TextBlock Text="→" FontSize="14" Foreground="#C84B4B" Margin="0,0,10,0"/>
							<TextBlock Text="Déconnexion" FontSize="13" Foreground="#C84B4B"/>
						</StackPanel>
					</Border>
				</StackPanel>
			</Grid>
		</Border>

		<!-- ══ MAIN CONTENT ══ -->
		<ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
			<StackPanel Margin="40,36,40,40">

				<!-- Header -->
				<Grid Margin="0,0,0,32">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>
					<StackPanel>
						<TextBlock FontSize="11" Foreground="#ABABAB" Margin="0,0,0,6">
							<Run Text="BONJOUR,  "/>
							<Run Text="{Binding Nom}" FontWeight="600"/>
						</TextBlock>
						<TextBlock Text="Tableau de bord" FontSize="26" FontWeight="700" Foreground="#1A1A1A"/>
					</StackPanel>
					<Border Grid.Column="1" Background="White" CornerRadius="10" Padding="16,10"
                            BorderBrush="#E8E7E3" BorderThickness="1"
                            VerticalAlignment="Center" Cursor="Hand">
						<Border.InputBindings>
							<MouseBinding MouseAction="LeftClick" Command="{Binding OpenCoursCommand}"/>
						</Border.InputBindings>
						<StackPanel Orientation="Horizontal">
							<TextBlock Text="+" FontSize="15" FontWeight="700"
                                       Foreground="#1A1A1A" Margin="0,0,8,0"/>
							<TextBlock Text="Importer un cours" FontSize="13"
                                       FontWeight="500" Foreground="#1A1A1A"/>
						</StackPanel>
					</Border>
				</Grid>

				<!-- Stats Cards -->
				<Grid Margin="0,0,0,28">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="14"/>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="14"/>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>
					<Border Grid.Column="0" Style="{StaticResource Card}" Padding="22,20">
						<StackPanel>
							<TextBlock Text="{Binding TotalCours, FallbackValue=0}"
                                       FontSize="32" FontWeight="700" Foreground="#1A1A1A"/>
							<TextBlock Text="Cours importés" FontSize="12"
                                       Foreground="#ABABAB" Margin="0,4,0,0"/>
						</StackPanel>
					</Border>
					<Border Grid.Column="2" Style="{StaticResource Card}" Padding="22,20">
						<StackPanel>
							<TextBlock Text="0" FontSize="32" FontWeight="700" Foreground="#1A1A1A"/>
							<TextBlock Text="Examens créés" FontSize="12"
                                       Foreground="#ABABAB" Margin="0,4,0,0"/>
						</StackPanel>
					</Border>
					<Border Grid.Column="4" Style="{StaticResource Card}" Padding="22,20">
						<StackPanel>
							<TextBlock Text="0" FontSize="32" FontWeight="700" Foreground="#1A1A1A"/>
							<TextBlock Text="Quiz créés" FontSize="12"
                                       Foreground="#ABABAB" Margin="0,4,0,0"/>
						</StackPanel>
					</Border>
				</Grid>

				<!-- Cours récents -->
				<Border Style="{StaticResource Card}" Padding="28,24">
					<StackPanel>
						<Grid Margin="0,0,0,22">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="Auto"/>
							</Grid.ColumnDefinitions>
							<StackPanel>
								<TextBlock Text="Mes cours récents" FontSize="15"
                                           FontWeight="600" Foreground="#1A1A1A"/>
								<TextBlock FontSize="12" Foreground="#ABABAB" Margin="0,4,0,0">
									<Run Text="{Binding TotalCours, FallbackValue=0}"/>
									<Run Text=" cours au total"/>
								</TextBlock>
							</StackPanel>
							<Border Grid.Column="1" CornerRadius="8" Padding="14,7" Cursor="Hand"
                                    BorderBrush="#E8E7E3" BorderThickness="1"
                                    VerticalAlignment="Center">
								<Border.Style>
									<Style TargetType="Border">
										<Setter Property="Background" Value="Transparent"/>
										<Style.Triggers>
											<Trigger Property="IsMouseOver" Value="True">
												<Setter Property="Background" Value="#F5F4F0"/>
											</Trigger>
										</Style.Triggers>
									</Style>
								</Border.Style>
								<Border.InputBindings>
									<MouseBinding MouseAction="LeftClick" Command="{Binding OpenCoursCommand}"/>
								</Border.InputBindings>
								<TextBlock Text="Voir tous les cours →" FontSize="12"
                                           Foreground="#444444" FontWeight="500"/>
							</Border>
						</Grid>

						<Border Height="1" Background="#F0EFE8" Margin="0,0,0,16"/>

						<ItemsControl ItemsSource="{Binding DerniersCours}">
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Border Padding="0,14" BorderBrush="#F0EFE8" BorderThickness="0,0,0,1">
										<Grid>
											<Grid.ColumnDefinitions>
												<ColumnDefinition Width="Auto"/>
												<ColumnDefinition Width="*"/>
												<ColumnDefinition Width="Auto"/>
											</Grid.ColumnDefinitions>
											<Border Grid.Column="0" Width="38" Height="38"
                                                    Background="#F5F4F0" CornerRadius="9" Margin="0,0,16,0">
												<TextBlock Text="▤" FontSize="15"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" Foreground="#6B6B6B"/>
											</Border>
											<StackPanel Grid.Column="1" VerticalAlignment="Center">
												<TextBlock Text="{Binding Titre}" FontSize="13"
                                                           FontWeight="500" Foreground="#1A1A1A"/>
												<TextBlock FontSize="11" Foreground="#ABABAB" Margin="0,3,0,0">
													<Run Text="Importé le "/>
													<Run Text="{Binding DateImport, StringFormat='{}{0:dd MMM yyyy}'}"/>
												</TextBlock>
											</StackPanel>
											<Border Grid.Column="2" CornerRadius="7" Padding="10,5"
                                                    Background="#F5F4F0" VerticalAlignment="Center">
												<TextBlock Text="{Binding DateImport, StringFormat='{}{0:dd/MM/yy}'}"
                                                           FontSize="11" Foreground="#6B6B6B"/>
											</Border>
										</Grid>
									</Border>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>

						<StackPanel Margin="0,24" HorizontalAlignment="Center"
                                    Visibility="{Binding HasNoCours, Converter={StaticResource BoolToVis}}">
							<TextBlock Text="Accédez rapidement à vos derniers cours"
                                       FontSize="14" Foreground="#ABABAB" HorizontalAlignment="Center"/>
						</StackPanel>
					</StackPanel>
				</Border>

			</StackPanel>
		</ScrollViewer>
	</Grid>
</Window>
