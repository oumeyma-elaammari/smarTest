<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══════════════════════════════════════════
         COULEURS
    ══════════════════════════════════════════ -->
    <Color x:Key="NavyColor">#0f1e3d</Color>
    <Color x:Key="NavyLightColor">#1a2e5a</Color>
    <Color x:Key="AccentColor">#4f8ef7</Color>
    <Color x:Key="BgColor">#f0f3f9</Color>
    <Color x:Key="BorderColor">#e2e8f4</Color>
    <Color x:Key="MutedColor">#8899b8</Color>
    <Color x:Key="TextColor">#0f1e3d</Color>
    <Color x:Key="SubTextColor">#6b7a99</Color>

    <SolidColorBrush x:Key="NavyBrush"       Color="{StaticResource NavyColor}"/>
    <SolidColorBrush x:Key="NavyLightBrush"  Color="{StaticResource NavyLightColor}"/>
    <SolidColorBrush x:Key="AccentBrush"     Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="BgBrush"         Color="{StaticResource BgColor}"/>
    <SolidColorBrush x:Key="BorderBrush"     Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="MutedBrush"      Color="{StaticResource MutedColor}"/>
    <SolidColorBrush x:Key="TextBrush"       Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="SubTextBrush"    Color="{StaticResource SubTextColor}"/>
    <SolidColorBrush x:Key="WhiteBrush"      Color="White"/>

    <!-- ══════════════════════════════════════════
         CONVERTISSEURS
    ══════════════════════════════════════════ -->
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>

    <!-- ══════════════════════════════════════════
         STYLE BOUTON PRIMAIRE (navy plein)
    ══════════════════════════════════════════ -->
    <Style x:Key="PrimaryBtn" TargetType="Button">
        <Setter Property="Height" Value="42"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="9">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="0.88"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.6"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Background" Value="{StaticResource NavyBrush}"/>
    </Style>

    <!-- ══════════════════════════════════════════
         STYLE BOUTON SECONDAIRE (outline)
    ══════════════════════════════════════════ -->
    <Style x:Key="SecondaryBtn" TargetType="Button">
        <Setter Property="Height" Value="42"/>
        <Setter Property="Foreground" Value="{StaticResource NavyLightBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="9"
                            BorderBrush="#d4dce8"
                            BorderThickness="1">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#f0f3f9"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.6"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Background" Value="White"/>
    </Style>

    <!-- ══════════════════════════════════════════
         STYLE CHAMP DE SAISIE
    ══════════════════════════════════════════ -->
    <Style x:Key="InputBox" TargetType="TextBox">
        <Setter Property="Height" Value="42"/>
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="BorderBrush" Value="#d8e0f0"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="9">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource NavyLightBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════
         STYLE PASSWORD BOX
    ══════════════════════════════════════════ -->
    <Style x:Key="InputPassword" TargetType="PasswordBox">
        <Setter Property="Height" Value="42"/>
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="BorderBrush" Value="#d8e0f0"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="9">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════
         LABEL CHAMP
    ══════════════════════════════════════════ -->
    <Style x:Key="FieldLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <!-- ══════════════════════════════════════════
         ALERTE ERREUR
    ══════════════════════════════════════════ -->
    <Style x:Key="AlertError" TargetType="Border">
        <Setter Property="Background" Value="#fcebeb"/>
        <Setter Property="BorderBrush" Value="#f7c1c1"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
    </Style>

    <!-- ══════════════════════════════════════════
         ALERTE SUCCÈS
    ══════════════════════════════════════════ -->
    <Style x:Key="AlertSuccess" TargetType="Border">
        <Setter Property="Background" Value="#eaf3de"/>
        <Setter Property="BorderBrush" Value="#c0dd97"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
    </Style>

    <!-- ══════════════════════════════════════════
         CARTE PRINCIPALE
    ══════════════════════════════════════════ -->
    <Style x:Key="MainCard" TargetType="Border">
        <Setter Property="Background" Value="White"/>
        <Setter Property="CornerRadius" Value="20"/>
        <Setter Property="Padding" Value="40"/>
        <Setter Property="Width" Value="420"/>
    </Style>

    <!-- ══════════════════════════════════════════
         BRAND TITLE
    ══════════════════════════════════════════ -->
    <Style x:Key="BrandTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Georgia"/>
        <Setter Property="FontSize" Value="26"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource NavyBrush}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <!-- ══════════════════════════════════════════
         BRAND SUBTITLE
    ══════════════════════════════════════════ -->
    <Style x:Key="BrandSub" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,0,20"/>
        <Setter Property="FontWeight" Value="Normal"/>
    </Style>

    <!-- ══════════════════════════════════════════
         PAGE LABEL BADGE
    ══════════════════════════════════════════ -->
    <Style x:Key="PageLabel" TargetType="Border">
        <Setter Property="Background" Value="#e8eef8"/>
        <Setter Property="CornerRadius" Value="20"/>
        <Setter Property="Padding" Value="10,3"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <!-- ══════════════════════════════════════════
         ACCENT LINE
    ══════════════════════════════════════════ -->
    <Style x:Key="AccentLine" TargetType="Border">
        <Setter Property="Width" Value="36"/>
        <Setter Property="Height" Value="2"/>
        <Setter Property="Background" Value="{StaticResource NavyBrush}"/>
        <Setter Property="CornerRadius" Value="2"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,6,0,16"/>
    </Style>

    <!-- ══════════════════════════════════════════
         ICON RING
    ══════════════════════════════════════════ -->
    <Style x:Key="IconRing" TargetType="Border">
        <Setter Property="Width" Value="68"/>
        <Setter Property="Height" Value="68"/>
        <Setter Property="CornerRadius" Value="34"/>
        <Setter Property="Background" Value="#e8eef8"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,0,16"/>
    </Style>

    <!-- ══════════════════════════════════════════
         FOOTER TEXT
    ══════════════════════════════════════════ -->
    <Style x:Key="FooterText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="#aab4cc"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,16,0,0"/>
    </Style>

</ResourceDictionary>
