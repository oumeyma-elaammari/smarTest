<Window x:Class="smartest_desktop.Views.ForgotPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmarTest — Mot de passe oublié"
        Height="600" Width="900"
        MinHeight="500" MinWidth="700"
        ResizeMode="CanResize"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#f0f3f9">

	<Window.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary Source="/Views/Styles/AuthStyles.xaml"/>
			</ResourceDictionary.MergedDictionaries>
		</ResourceDictionary>
	</Window.Resources>

	<Grid Background="#f0f3f9">

		<Border Style="{StaticResource MainCard}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
			<Border.Effect>
				<DropShadowEffect Color="#000000" Opacity="0.07"
                                  BlurRadius="24" ShadowDepth="3"/>
			</Border.Effect>

			<StackPanel>

				<!-- Brand -->
				<TextBlock Text="SmarTest" Style="{StaticResource BrandTitle}"/>
				<TextBlock Text="PLATEFORME D'ÉVALUATION" Style="{StaticResource BrandSub}"/>

				<!-- Icône -->
				<Border Style="{StaticResource IconRing}">
					<TextBlock Text="✉" FontSize="30"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#1a2e5a"/>
				</Border>

				<!-- Titre -->
				<TextBlock Text="Mot de passe oublié ?" FontFamily="Georgia" FontSize="20"
                           Foreground="#0f1e3d" HorizontalAlignment="Center"/>
				<Border Style="{StaticResource AccentLine}"/>

				<TextBlock Text="Entrez votre email pour recevoir un lien de réinitialisation."
                           FontSize="12" Foreground="#6b7a99" HorizontalAlignment="Center"
                           TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,20"/>

				<!-- Succès -->
				<Border Style="{StaticResource AlertSuccess}"
                        Visibility="{Binding HasSuccess, Converter={StaticResource BoolToVis}}">
					<TextBlock Text="{Binding SuccessMessage}" Foreground="#27500a"
                               FontSize="12" TextWrapping="Wrap"/>
				</Border>

				<!-- Erreur -->
				<Border Style="{StaticResource AlertError}"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
					<TextBlock Text="{Binding ErrorMessage}" Foreground="#791f1f"
                               FontSize="12" TextWrapping="Wrap"/>
				</Border>

				<!-- Email -->
				<TextBlock Text="Email" Style="{StaticResource FieldLabel}"/>
				<TextBox Style="{StaticResource InputBox}"
                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12"/>

				<!-- Bouton Envoyer -->
				<Button Style="{StaticResource PrimaryBtn}"
                        Command="{Binding SendCommand}"
                        Margin="0,0,0,10">
					<TextBlock>
						<TextBlock.Style>
							<Style TargetType="TextBlock">
								<Setter Property="Text" Value="Envoyer le lien"/>
								<Style.Triggers>
									<DataTrigger Binding="{Binding IsLoading}" Value="True">
										<Setter Property="Text" Value="Envoi en cours..."/>
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</TextBlock.Style>
					</TextBlock>
				</Button>

				<!-- Bouton J'ai reçu le code -->
				<Button Style="{StaticResource SecondaryBtn}"
                        Command="{Binding ResetPasswordCommand}"
                        Margin="0,0,0,10">
					<TextBlock Text="J'ai reçu le code — Saisir le nouveau mot de passe"/>
				</Button>

				<!-- Bouton Retour -->
				<Button Style="{StaticResource SecondaryBtn}"
                        Command="{Binding BackToLoginCommand}">
					<TextBlock Text="Retour à la connexion"/>
				</Button>

				<!-- Footer -->
				<TextBlock Text="SmarTest — ENSA Oujda" Style="{StaticResource FooterText}"/>

			</StackPanel>
		</Border>
	</Grid>
</Window>
