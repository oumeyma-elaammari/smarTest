<Window x:Class="smartest_desktop.Views.ForgotPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:smartest_desktop.ViewModels"
        Title="SmarTest — Mot de passe oublié"
        Height="600" Width="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F3F4F6">

	<Window.DataContext>
		<vm:ForgotPasswordViewModel />
	</Window.DataContext>

	<Window.Resources>
		<BooleanToVisibilityConverter x:Key="BoolToVis"/>
	</Window.Resources>

	<Border Background="White"
            CornerRadius="12"
            Margin="24"
            Padding="36">
		<StackPanel VerticalAlignment="Center">

			<!-- Header -->
			<TextBlock Text="SmarTest"
                       FontSize="26" FontWeight="Bold"
                       Foreground="#1a2e5a"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4"/>
			<TextBlock Text="Mot de passe oublié ?"
                       FontSize="13" Foreground="#6B7280"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>
			<TextBlock Text="Entrez votre email pour recevoir un lien de réinitialisation"
                       FontSize="12" Foreground="#9CA3AF"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Margin="0,0,0,28"/>

			<!-- Succès -->
			<Border Background="#F0FDF4"
                    BorderBrush="#BBF7D0"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12,8"
                    Margin="0,0,0,14"
                    Visibility="{Binding HasSuccess,
                        Converter={StaticResource BoolToVis}}">
				<TextBlock Text="{Binding SuccessMessage}"
                           Foreground="#16A34A"
                           FontSize="12"
                           TextWrapping="Wrap"/>
			</Border>

			<!-- Erreur -->
			<Border Background="#FEF2F2"
                    BorderBrush="#FECACA"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12,8"
                    Margin="0,0,0,14"
                    Visibility="{Binding HasError,
                        Converter={StaticResource BoolToVis}}">
				<TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#DC2626"
                           FontSize="12"
                           TextWrapping="Wrap"/>
			</Border>

			<!-- Email -->
			<TextBlock Text="Email"
                       FontWeight="SemiBold" FontSize="13"
                       Margin="0,0,0,4"/>
			<TextBox Height="40" Padding="10,0"
                     FontSize="13"
                     BorderBrush="#D1D5DB" BorderThickness="1"
                     VerticalContentAlignment="Center"
                     Text="{Binding Email,
                         UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,20"/>

			<!-- Bouton -->
			<Button Height="42"
                    Foreground="White"
                    FontWeight="SemiBold" FontSize="13"
                    BorderThickness="0" Cursor="Hand"
                    Command="{Binding SendCommand}">
				<Button.Style>
					<Style TargetType="Button">
						<Setter Property="Background" Value="#1a2e5a"/>
						<Setter Property="Template">
							<Setter.Value>
								<ControlTemplate TargetType="Button">
									<Border
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="6">
										<ContentPresenter
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
									</Border>
									<ControlTemplate.Triggers>
										<Trigger Property="IsMouseOver"
                                                 Value="True">
											<Setter Property="Background"
                                                    Value="#15244a"/>
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Setter.Value>
						</Setter>
					</Style>
				</Button.Style>
				<TextBlock>
					<TextBlock.Style>
						<Style TargetType="TextBlock">
							<Setter Property="Text" Value="Envoyer le lien"/>
							<Style.Triggers>
								<DataTrigger Binding="{Binding IsLoading}"
                                             Value="True">
									<Setter Property="Text" Value="Envoi..."/>
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</TextBlock.Style>
				</TextBlock>
			</Button>

		</StackPanel>
	</Border>
</Window>