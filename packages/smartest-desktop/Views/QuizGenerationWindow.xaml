<Window x:Class="smartest_desktop.Views.QuizGenerationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:smartest_desktop.ViewModels"
        xmlns:helpers="clr-namespace:smartest_desktop.Helpers"

        Title="SmarTest — Générer un quiz"
        Height="720" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#F8F8F6"
        FontFamily="Segoe UI">


    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="PrimaryBtn" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#1A1A1A"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#333333"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StyledCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E8E7E3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Height" Value="44"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════
             HEADER
        ══════════════════════════════════════ -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E8E7E3"
                BorderThickness="0,0,0,1" Padding="28,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Bouton retour -->
                <Border Grid.Column="0" Width="38" Height="38" CornerRadius="9"
                        Background="#F0EFE8" Cursor="Hand" Margin="0,0,20,0">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding AnnulerCommand}"/>
                    </Border.InputBindings>
                    <TextBlock Text="←" FontSize="18" FontWeight="300" Foreground="#1A1A1A"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Logo + sous-titre -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="8" Height="8" CornerRadius="4" Background="#1A1A1A"
                                VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock FontSize="17" FontWeight="700" Foreground="#1A1A1A">
                            <Run Text="Smar"/><Run Text="Test" Foreground="#6B6B6B"/>
                        </TextBlock>
                    </StackPanel>
                    <TextBlock Text="Génération de quiz par IA locale"
                               FontSize="11" Foreground="#ABABAB" Margin="16,2,0,0"/>
                </StackPanel>

                <!-- Badge Ollama -->
                <Border Grid.Column="2" Background="#F0F9FF" BorderBrush="#BAE6FD"
                        BorderThickness="1" CornerRadius="8" Padding="12,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🤖" FontSize="13" Margin="0,0,6,0"/>
                        <TextBlock Text="Ollama" FontSize="12" FontWeight="600" Foreground="#0369A1"/>
                        <TextBlock Text=" · IA locale" FontSize="11" Foreground="#7DD3FC"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════
             CONTENU PRINCIPAL
        ══════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══════════════════════════════════════
                 COLONNE GAUCHE — Paramètres
            ══════════════════════════════════════ -->
            <Border Grid.Column="0" Background="#FAFAF9"
                    BorderBrush="#E8E7E3" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="28,32,28,32">

                        <!-- Titre section -->
                        <TextBlock Text="Configuration du quiz"
                                   FontSize="18" FontWeight="700" Foreground="#1A1A1A"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="Définissez les paramètres avant la génération"
                                   FontSize="12" Foreground="#ABABAB" Margin="0,0,0,28"/>

                        <!-- ── Titre du quiz ── -->
                        <TextBlock Text="TITRE DU QUIZ" FontSize="10" FontWeight="700"
                                   Foreground="#9CA3AF" Margin="0,0,0,8"/>
                        <Border Background="White" CornerRadius="10" BorderBrush="#E8E7E3"
                                BorderThickness="1" Padding="14,12" Margin="0,0,0,24">
                            <Grid>
                                <TextBlock Text="Quiz — Titre automatique si vide…"
                                           FontSize="12" Foreground="#CACACA"
                                           VerticalAlignment="Center" IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                               


                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBox Text="{Binding TitreQuiz, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0" Background="Transparent"
                                         FontSize="12" Foreground="#1A1A1A"
                                         VerticalAlignment="Center" CaretBrush="#1A1A1A"/>
                            </Grid>
                        </Border>

                        <!-- ── Nombre de questions ── -->
                        <TextBlock Text="NOMBRE DE QUESTIONS" FontSize="10" FontWeight="700"
                                   Foreground="#9CA3AF" Margin="0,0,0,8"/>
                        <ComboBox Style="{StaticResource StyledCombo}"
                                  ItemsSource="{Binding NombresQuestions}"
                                  SelectedItem="{Binding NombreQuestions}"
                                  Margin="0,0,0,24"/>

                        <!-- ── Niveau de difficulté ── -->
                        <TextBlock Text="NIVEAU DE DIFFICULTÉ" FontSize="10" FontWeight="700"
                                   Foreground="#9CA3AF" Margin="0,0,0,10"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,28">

                            <!-- Facile -->
                            <Border CornerRadius="9" Padding="16,10" Cursor="Hand"
                                    Margin="0,0,8,0" Width="110">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding SetDifficulteCommand}"
                                                  CommandParameter="Facile"/>
                                </Border.InputBindings>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#F5F4F0"/>
                                        <Setter Property="BorderBrush" Value="#E8E7E3"/>
                                        <Setter Property="BorderThickness" Value="1.5"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Difficulte}" Value="Facile">
                                                <Setter Property="Background" Value="#F0FDF4"/>
                                                <Setter Property="BorderBrush" Value="#86EFAC"/>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderBrush" Value="#86EFAC"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="🟢" FontSize="16" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Facile" FontSize="11" FontWeight="600"
                                               Foreground="#16A34A" HorizontalAlignment="Center"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Moyen -->
                            <Border CornerRadius="9" Padding="16,10" Cursor="Hand"
                                    Margin="0,0,8,0" Width="110">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding SetDifficulteCommand}"
                                                  CommandParameter="Moyen"/>
                                </Border.InputBindings>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#F5F4F0"/>
                                        <Setter Property="BorderBrush" Value="#E8E7E3"/>
                                        <Setter Property="BorderThickness" Value="1.5"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Difficulte}" Value="Moyen">
                                                <Setter Property="Background" Value="#FFFBEB"/>
                                                <Setter Property="BorderBrush" Value="#FCD34D"/>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderBrush" Value="#FCD34D"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="🟡" FontSize="16" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Moyen" FontSize="11" FontWeight="600"
                                               Foreground="#D97706" HorizontalAlignment="Center"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Difficile -->
                            <Border CornerRadius="9" Padding="16,10" Cursor="Hand" Width="110">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding SetDifficulteCommand}"
                                                  CommandParameter="Difficile"/>
                                </Border.InputBindings>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#F5F4F0"/>
                                        <Setter Property="BorderBrush" Value="#E8E7E3"/>
                                        <Setter Property="BorderThickness" Value="1.5"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Difficulte}" Value="Difficile">
                                                <Setter Property="Background" Value="#FFF1F2"/>
                                                <Setter Property="BorderBrush" Value="#FCA5A5"/>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderBrush" Value="#FCA5A5"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="🔴" FontSize="16" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Difficile" FontSize="11" FontWeight="600"
                                               Foreground="#DC2626" HorizontalAlignment="Center"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ── Message statut ── -->
                        <Border CornerRadius="10" Padding="14,12" Margin="0,0,0,12"
                                Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1"
                                Visibility="{Binding HasStatus, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                                       Foreground="#1D4ED8" TextWrapping="Wrap"/>
                        </Border>

                        <!-- ── Message erreur ── -->
                        <Border CornerRadius="10" Padding="14,12" Margin="0,0,0,12"
                                Background="#FDF0F0" BorderBrush="#F5C6C6" BorderThickness="1"
                                Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding ErrorMessage}" FontSize="12"
                                       Foreground="#C84B4B" TextWrapping="Wrap"/>
                        </Border>

                        <!-- ── Bouton Générer ── -->
                        <Border Margin="0,8,0,0">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding GenererCommand}"/>
                            </Border.InputBindings>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource PrimaryBtn}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGenerating}" Value="True">
                                            <Setter Property="Background" Value="#6B7280"/>
                                            <Setter Property="Cursor" Value="Wait"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="✨" FontSize="14" Margin="0,0,8,0"
                                           Visibility="{Binding IsNotGenerating, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Text="⟳" FontSize="14" Margin="0,0,8,0"
                                           Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock FontSize="13" FontWeight="600" Foreground="White">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Générer le quiz"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsGenerating}" Value="True">
                                                    <Setter Property="Text" Value="Génération en cours..."/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- ── Info Ollama ── -->
                        <Border CornerRadius="8" Padding="12,10" Margin="0,16,0,0"
                                Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="ℹ️  Requis : Ollama doit être démarré"
                                           FontSize="11" Foreground="#64748B" FontWeight="600"/>
                                <TextBlock Text="Commande : ollama serve" FontSize="10"
                                           Foreground="#94A3B8" Margin="0,4,0,0"
                                           FontFamily="Consolas"/>
                                <TextBlock Text="Modèle : llama3.2 ou mistral" FontSize="10"
                                           Foreground="#94A3B8" Margin="0,2,0,0"
                                           FontFamily="Consolas"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ══════════════════════════════════════
                 COLONNE DROITE — Sélection du cours
            ══════════════════════════════════════ -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Padding="28,24,28,16" Background="#F8F8F6"
                        BorderBrush="#E8E7E3" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="Sélectionner un cours"
                                   FontSize="18" FontWeight="700" Foreground="#1A1A1A"/>
                        <TextBlock Text="Choisissez le cours sur lequel baser le quiz"
                                   FontSize="12" Foreground="#ABABAB" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Liste des cours -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="28,20,28,28">

                        <!-- Aucun cours -->
                        <StackPanel HorizontalAlignment="Center" Margin="0,60,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CoursDisponibles.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="📂" FontSize="40" HorizontalAlignment="Center"
                                       Margin="0,0,0,12"/>
                            <TextBlock Text="Aucun cours disponible" FontSize="14" FontWeight="600"
                                       Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                            <TextBlock Text="Importez des cours depuis &quot;Mes cours&quot;"
                                       FontSize="12" Foreground="#ABABAB"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"
                                       TextAlignment="Center"/>
                        </StackPanel>

                        <!-- Cours disponibles -->
                        <ItemsControl ItemsSource="{Binding CoursDisponibles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10" Cursor="Hand">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.SelectionnerCoursCommand,
                                                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                                          CommandParameter="{Binding}"/>
                                        </Border.InputBindings>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="White"/>
                                                <Setter Property="CornerRadius" Value="12"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                                <Setter Property="BorderBrush" Value="#E8E7E3"/>
                                                <Setter Property="Padding" Value="16,14"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#FAFAFA"/>
                                                        <Setter Property="BorderBrush" Value="#C8C7C3"/>
                                                    </Trigger>
                                                    <!-- Bordure violette si ce cours est sélectionné -->
                                                    <DataTrigger Binding="{Binding EstSelectionne}" Value="True">
                                                        <Setter Property="Background" Value="#F8F0FF"/>
                                                        <Setter Property="BorderBrush" Value="#A855F7"/>
                                                    </DataTrigger>



                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Icône fichier -->
                                            <Border Grid.Column="0" Width="44" Height="44"
                                                    Background="#F5F4F0" CornerRadius="10"
                                                    Margin="0,0,14,0">
                                                <TextBlock Text="📄" FontSize="18"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- Titre + méta -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Titre}"
                                                           FontSize="13" FontWeight="600"
                                                           Foreground="#1A1A1A"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <Border CornerRadius="4" Padding="6,2"
                                                            Background="#F0EFE8" Margin="0,0,6,0">
                                                        <TextBlock Text="{Binding TypeFichier}"
                                                                   FontSize="10" FontWeight="600"
                                                                   Foreground="#6B6B6B"/>
                                                    </Border>
                                                    <TextBlock FontSize="10" Foreground="#ABABAB"
                                                               Text="{Binding DateImport,
                                                                      StringFormat='Importé le {0:dd/MM/yyyy}'}"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Checkmark violet si sélectionné -->
                                            <Border Grid.Column="2" Width="28" Height="28"
        CornerRadius="14" Background="#A855F7"
        VerticalAlignment="Center">

                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>

                                                            <DataTrigger Binding="{Binding EstSelectionne}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>

                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>

                                                <TextBlock Text="✓" FontSize="13" FontWeight="700"
               Foreground="White"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Bandeau cours sélectionné -->
                        <Border CornerRadius="10" Padding="14,12" Margin="0,8,0,0"
                                Background="#F5F0FF" BorderBrush="#DDD6FE" BorderThickness="1"
                                Visibility="{Binding HasCoursSelectionne, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✅" FontSize="13" Margin="0,0,8,0"/>
                                <StackPanel>
                                    <TextBlock Text="Cours sélectionné :" FontSize="10"
                                               Foreground="#7C3AED" FontWeight="600"/>
                                    <TextBlock Text="{Binding CoursSelectionne.Titre}"
                                               FontSize="12" Foreground="#4C1D95" FontWeight="700"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
