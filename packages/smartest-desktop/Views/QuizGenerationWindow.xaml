<Window x:Class="smartest_desktop.Views.QuizGenerationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:smartest_desktop.ViewModels"
        Title="SmarTest — Générer un quiz"
        Height="720" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#F8F8F6"
        FontFamily="Segoe UI">

	<Window.DataContext>
		<vm:QuizGenerationViewModel/>
	</Window.DataContext>

	<Window.Resources>
		<BooleanToVisibilityConverter x:Key="BoolToVis"/>

		<Style x:Key="PrimaryBtn" TargetType="Border">
			<Setter Property="CornerRadius" Value="10"/>
			<Setter Property="Padding" Value="20,12"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Background" Value="#1A1A1A"/>
			<Style.Triggers>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="#333333"/>
				</Trigger>
			</Style.Triggers>
		</Style>

		<Style x:Key="SecondaryBtn" TargetType="Border">
			<Setter Property="CornerRadius" Value="9"/>
			<Setter Property="Padding" Value="16,10"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Background" Value="#F0EFE8"/>
			<Setter Property="BorderBrush" Value="#E8E7E3"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Style.Triggers>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="#E8E7E0"/>
				</Trigger>
			</Style.Triggers>
		</Style>

		<Style x:Key="StyledCombo" TargetType="ComboBox">
			<Setter Property="Background" Value="White"/>
			<Setter Property="BorderBrush" Value="#E8E7E3"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Padding" Value="12,10"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="Foreground" Value="#1A1A1A"/>
			<Setter Property="Height" Value="44"/>
		</Style>
	</Window.Resources>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<!-- ══ HEADER ══ -->
		<Border Grid.Row="0" Background="White" BorderBrush="#E8E7E3"
                BorderThickness="0,0,0,1" Padding="28,18">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>

				<Border Grid.Column="0" Width="38" Height="38" CornerRadius="9"
                        Background="#F0EFE8" Cursor="Hand" Margin="0,0,20,0">
					<Border.InputBindings>
						<MouseBinding MouseAction="LeftClick" Command="{Binding AnnulerCommand}"/>
					</Border.InputBindings>
					<TextBlock Text="←" FontSize="18" FontWeight="300" Foreground="#1A1A1A"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
				</Border>

				<StackPanel Grid.Column="1" VerticalAlignment="Center">
					<StackPanel Orientation="Horizontal">
						<Border Width="8" Height="8" CornerRadius="4" Background="#1A1A1A"
                                VerticalAlignment="Center" Margin="0,0,8,0"/>
						<TextBlock FontSize="17" FontWeight="700" Foreground="#1A1A1A">
							<Run Text="Smar"/>
							<Run Text="Test" Foreground="#6B6B6B"/>
						</TextBlock>
					</StackPanel>
					<TextBlock Text="Génération de quiz par IA locale"
                               FontSize="11" Foreground="#ABABAB" Margin="16,2,0,0"/>
				</StackPanel>

				<Border Grid.Column="2" Background="#F0F9FF" BorderBrush="#BAE6FD"
                        BorderThickness="1" CornerRadius="8" Padding="12,8">
					<StackPanel Orientation="Horizontal">
						<TextBlock Text="🤖" FontSize="13" Margin="0,0,6,0"/>
						<TextBlock Text="Ollama" FontSize="12" FontWeight="600" Foreground="#0369A1"/>
						<TextBlock Text=" · IA locale" FontSize="11" Foreground="#7DD3FC"/>
					</StackPanel>
				</Border>
			</Grid>
		</Border>

		<!-- ══ CONTENU — 2 colonnes ══ -->
		<Grid Grid.Row="1">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="380"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>

			<!-- ══ COLONNE GAUCHE — Paramètres ══ -->
			<Border Grid.Column="0" Background="#FAFAF9"
                    BorderBrush="#E8E7E3" BorderThickness="0,0,1,0">
				<ScrollViewer VerticalScrollBarVisibility="Auto">
					<StackPanel Margin="28,32,28,32">

						<TextBlock Text="Configuration du quiz"
                                   FontSize="18" FontWeight="700" Foreground="#1A1A1A" Margin="0,0,0,4"/>
						<TextBlock Text="Importez un cours puis définissez les paramètres"
                                   FontSize="12" Foreground="#ABABAB" Margin="0,0,0,28"/>

						<!-- Titre du quiz -->
						<TextBlock Text="TITRE DU QUIZ" FontSize="10" FontWeight="700"
                                   Foreground="#9CA3AF" Margin="0,0,0,8"/>
						<Border Background="White" CornerRadius="10" BorderBrush="#E8E7E3"
                                BorderThickness="1" Padding="14,12" Margin="0,0,0,24">
							<TextBox Text="{Binding TitreQuiz, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0" Background="Transparent"
                                     FontSize="12" Foreground="#1A1A1A"
                                     VerticalAlignment="Center" CaretBrush="#1A1A1A"/>
						</Border>

						<!-- Nombre de questions -->
						<TextBlock Text="NOMBRE DE QUESTIONS" FontSize="10" FontWeight="700"
                                   Foreground="#9CA3AF" Margin="0,0,0,8"/>
						<ComboBox Style="{StaticResource StyledCombo}"
                                  ItemsSource="{Binding NombresQuestions}"
                                  SelectedItem="{Binding NombreQuestions}"
                                  Margin="0,0,0,24"/>

						<!-- Difficulté -->
						<TextBlock Text="NIVEAU DE DIFFICULTÉ" FontSize="10" FontWeight="700"
                                   Foreground="#9CA3AF" Margin="0,0,0,10"/>

						<StackPanel Orientation="Horizontal" Margin="0,0,0,28">
							<!-- Facile -->
							<Border CornerRadius="9" Padding="12,10" Cursor="Hand" Margin="0,0,8,0" Width="100">
								<Border.InputBindings>
									<MouseBinding MouseAction="LeftClick" Command="{Binding SetDifficulteCommand}" CommandParameter="Facile"/>
								</Border.InputBindings>
								<Border.Style>
									<Style TargetType="Border">
										<Setter Property="Background" Value="#F5F4F0"/>
										<Setter Property="BorderBrush" Value="#E8E7E3"/>
										<Setter Property="BorderThickness" Value="1.5"/>
										<Style.Triggers>
											<DataTrigger Binding="{Binding Difficulte}" Value="Facile">
												<Setter Property="Background" Value="#F0FDF4"/>
												<Setter Property="BorderBrush" Value="#86EFAC"/>
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</Border.Style>
								<StackPanel HorizontalAlignment="Center">
									<TextBlock Text="🟢" FontSize="16" HorizontalAlignment="Center"/>
									<TextBlock Text="Facile" FontSize="11" FontWeight="600"
                                               Foreground="#16A34A" HorizontalAlignment="Center" Margin="0,4,0,0"/>
								</StackPanel>
							</Border>

							<!-- Moyen -->
							<Border CornerRadius="9" Padding="12,10" Cursor="Hand" Margin="0,0,8,0" Width="100">
								<Border.InputBindings>
									<MouseBinding MouseAction="LeftClick" Command="{Binding SetDifficulteCommand}" CommandParameter="Moyen"/>
								</Border.InputBindings>
								<Border.Style>
									<Style TargetType="Border">
										<Setter Property="Background" Value="#F5F4F0"/>
										<Setter Property="BorderBrush" Value="#E8E7E3"/>
										<Setter Property="BorderThickness" Value="1.5"/>
										<Style.Triggers>
											<DataTrigger Binding="{Binding Difficulte}" Value="Moyen">
												<Setter Property="Background" Value="#FFFBEB"/>
												<Setter Property="BorderBrush" Value="#FCD34D"/>
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</Border.Style>
								<StackPanel HorizontalAlignment="Center">
									<TextBlock Text="🟡" FontSize="16" HorizontalAlignment="Center"/>
									<TextBlock Text="Moyen" FontSize="11" FontWeight="600"
                                               Foreground="#D97706" HorizontalAlignment="Center" Margin="0,4,0,0"/>
								</StackPanel>
							</Border>

							<!-- Difficile -->
							<Border CornerRadius="9" Padding="12,10" Cursor="Hand" Width="100">
								<Border.InputBindings>
									<MouseBinding MouseAction="LeftClick" Command="{Binding SetDifficulteCommand}" CommandParameter="Difficile"/>
								</Border.InputBindings>
								<Border.Style>
									<Style TargetType="Border">
										<Setter Property="Background" Value="#F5F4F0"/>
										<Setter Property="BorderBrush" Value="#E8E7E3"/>
										<Setter Property="BorderThickness" Value="1.5"/>
										<Style.Triggers>
											<DataTrigger Binding="{Binding Difficulte}" Value="Difficile">
												<Setter Property="Background" Value="#FFF1F2"/>
												<Setter Property="BorderBrush" Value="#FCA5A5"/>
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</Border.Style>
								<StackPanel HorizontalAlignment="Center">
									<TextBlock Text="🔴" FontSize="16" HorizontalAlignment="Center"/>
									<TextBlock Text="Difficile" FontSize="11" FontWeight="600"
                                               Foreground="#DC2626" HorizontalAlignment="Center" Margin="0,4,0,0"/>
								</StackPanel>
							</Border>
						</StackPanel>

						<!-- Statut -->
						<Border CornerRadius="10" Padding="14,12" Margin="0,0,0,12"
                                Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1"
                                Visibility="{Binding HasStatus, Converter={StaticResource BoolToVis}}">
							<TextBlock Text="{Binding StatusMessage}" FontSize="12"
                                       Foreground="#1D4ED8" TextWrapping="Wrap"/>
						</Border>

						<!-- Erreur -->
						<Border CornerRadius="10" Padding="14,12" Margin="0,0,0,12"
                                Background="#FDF0F0" BorderBrush="#F5C6C6" BorderThickness="1"
                                Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
							<TextBlock Text="{Binding ErrorMessage}" FontSize="12"
                                       Foreground="#C84B4B" TextWrapping="Wrap"/>
						</Border>

						<!-- Bouton Générer -->
						<Border Margin="0,8,0,0">
							<Border.InputBindings>
								<MouseBinding MouseAction="LeftClick" Command="{Binding GenererCommand}"/>
							</Border.InputBindings>
							<Border.Style>
								<Style TargetType="Border" BasedOn="{StaticResource PrimaryBtn}">
									<Style.Triggers>
										<DataTrigger Binding="{Binding IsGenerating}" Value="True">
											<Setter Property="Background" Value="#6B7280"/>
											<Setter Property="Cursor" Value="Wait"/>
										</DataTrigger>
										<DataTrigger Binding="{Binding HasCours}" Value="False">
											<Setter Property="Background" Value="#D1D5DB"/>
											<Setter Property="Cursor" Value="Arrow"/>
										</DataTrigger>
									</Style.Triggers>
								</Style>
							</Border.Style>
							<StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
								<TextBlock FontSize="14" Margin="0,0,8,0">
									<TextBlock.Style>
										<Style TargetType="TextBlock">
											<Setter Property="Text" Value="✨"/>
											<Style.Triggers>
												<DataTrigger Binding="{Binding IsGenerating}" Value="True">
													<Setter Property="Text" Value="⟳"/>
												</DataTrigger>
											</Style.Triggers>
										</Style>
									</TextBlock.Style>
								</TextBlock>
								<TextBlock FontSize="13" FontWeight="600" Foreground="White">
									<TextBlock.Style>
										<Style TargetType="TextBlock">
											<Setter Property="Text" Value="Générer le quiz"/>
											<Style.Triggers>
												<DataTrigger Binding="{Binding IsGenerating}" Value="True">
													<Setter Property="Text" Value="Génération en cours..."/>
												</DataTrigger>
												<DataTrigger Binding="{Binding HasCours}" Value="False">
													<Setter Property="Text" Value="Importez un cours d'abord"/>
												</DataTrigger>
											</Style.Triggers>
										</Style>
									</TextBlock.Style>
								</TextBlock>
							</StackPanel>
						</Border>

						<!-- Annuler génération -->
						<Border Margin="0,10,0,0" Padding="0,10"
                                Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVis}}">
							<Border.InputBindings>
								<MouseBinding MouseAction="LeftClick" Command="{Binding AnnulerGenerationCommand}"/>
							</Border.InputBindings>
							<Border.Style>
								<Style TargetType="Border" BasedOn="{StaticResource SecondaryBtn}"/>
							</Border.Style>
							<TextBlock Text="⛔  Annuler la génération" FontSize="12"
                                       FontWeight="600" Foreground="#DC2626" HorizontalAlignment="Center"/>
						</Border>

						<!-- Info Ollama -->
						<Border CornerRadius="8" Padding="12,10" Margin="0,16,0,0"
                                Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1">
							<StackPanel>
								<TextBlock Text="ℹ️  Requis : Ollama doit être démarré"
                                           FontSize="11" Foreground="#64748B" FontWeight="600"/>
								<TextBlock Text="Commande : ollama serve" FontSize="10"
                                           Foreground="#94A3B8" Margin="0,4,0,0" FontFamily="Consolas"/>
								<TextBlock Text="Formats supportés : PDF · DOCX · TXT" FontSize="10"
                                           Foreground="#94A3B8" Margin="0,2,0,0"/>
							</StackPanel>
						</Border>

					</StackPanel>
				</ScrollViewer>
			</Border>

			<!-- ══ COLONNE DROITE — Import + aperçu cours ══ -->
			<Grid Grid.Column="1">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
				</Grid.RowDefinitions>

				<!-- Header colonne droite -->
				<Border Grid.Row="0" Padding="28,20,28,16" Background="#F8F8F6"
                        BorderBrush="#E8E7E3" BorderThickness="0,0,0,1">
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>

						<StackPanel Grid.Column="0" VerticalAlignment="Center">
							<TextBlock Text="Cours à utiliser" FontSize="18" FontWeight="700" Foreground="#1A1A1A"/>
							<TextBlock Text="Importez un fichier PDF, DOCX ou TXT. Vous pouvez modifier le texte avant génération."
                                       FontSize="11" Foreground="#ABABAB" Margin="0,4,0,0" TextWrapping="Wrap"/>
						</StackPanel>

						<!-- Bouton importer -->
						<Border Grid.Column="1" CornerRadius="10" Cursor="Hand" Padding="16,10" VerticalAlignment="Center">
							<Border.InputBindings>
								<MouseBinding MouseAction="LeftClick" Command="{Binding ImporterFichierCommand}"/>
							</Border.InputBindings>
							<Border.Style>
								<Style TargetType="Border">
									<Setter Property="Background" Value="#1A1A1A"/>
									<Style.Triggers>
										<Trigger Property="IsMouseOver" Value="True">
											<Setter Property="Background" Value="#333333"/>
										</Trigger>
										<DataTrigger Binding="{Binding IsImporting}" Value="True">
											<Setter Property="Background" Value="#6B7280"/>
										</DataTrigger>
									</Style.Triggers>
								</Style>
							</Border.Style>
							<StackPanel Orientation="Horizontal">
								<TextBlock FontSize="14" Margin="0,0,8,0">
									<TextBlock.Style>
										<Style TargetType="TextBlock">
											<Setter Property="Text" Value="📂"/>
											<Style.Triggers>
												<DataTrigger Binding="{Binding IsImporting}" Value="True">
													<Setter Property="Text" Value="⟳"/>
												</DataTrigger>
											</Style.Triggers>
										</Style>
									</TextBlock.Style>
								</TextBlock>
								<TextBlock FontSize="12" FontWeight="600" Foreground="White">
									<TextBlock.Style>
										<Style TargetType="TextBlock">
											<Setter Property="Text" Value="Importer un cours"/>
											<Style.Triggers>
												<DataTrigger Binding="{Binding IsImporting}" Value="True">
													<Setter Property="Text" Value="Import en cours..."/>
												</DataTrigger>
												<DataTrigger Binding="{Binding HasCours}" Value="True">
													<Setter Property="Text" Value="Changer de fichier"/>
												</DataTrigger>
											</Style.Triggers>
										</Style>
									</TextBlock.Style>
								</TextBlock>
							</StackPanel>
						</Border>
					</Grid>
				</Border>

				<!-- Corps colonne droite -->
				<Grid Grid.Row="1">

					<!-- État vide -->
					<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,40">
						<StackPanel.Style>
							<Style TargetType="StackPanel">
								<Setter Property="Visibility" Value="Collapsed"/>
								<Style.Triggers>
									<DataTrigger Binding="{Binding HasCours}" Value="False">
										<Setter Property="Visibility" Value="Visible"/>
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</StackPanel.Style>

						<Border Width="320" Height="220" CornerRadius="16"
                                BorderBrush="#E8E7E3" BorderThickness="2"
                                Background="White" Cursor="Hand">
							<Border.InputBindings>
								<MouseBinding MouseAction="LeftClick" Command="{Binding ImporterFichierCommand}"/>
							</Border.InputBindings>
							<Border.Style>
								<Style TargetType="Border">
									<Style.Triggers>
										<Trigger Property="IsMouseOver" Value="True">
											<Setter Property="BorderBrush" Value="#A855F7"/>
											<Setter Property="Background" Value="#FDFAFF"/>
										</Trigger>
									</Style.Triggers>
								</Style>
							</Border.Style>
							<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
								<TextBlock Text="📂" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
								<TextBlock Text="Cliquez pour importer un cours"
                                           FontSize="14" FontWeight="600" Foreground="#1A1A1A"
                                           HorizontalAlignment="Center"/>
								<TextBlock Text="PDF  ·  DOCX  ·  TXT"
                                           FontSize="12" Foreground="#ABABAB"
                                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
							</StackPanel>
						</Border>

						<TextBlock Text="Le contenu reste exclusivement local — aucun envoi cloud"
                                   FontSize="11" Foreground="#C0C0C0"
                                   HorizontalAlignment="Center" Margin="0,16,0,0"/>
					</StackPanel>

					<!-- Cours importé -->
					<Grid>
						<Grid.Style>
							<Style TargetType="Grid">
								<Setter Property="Visibility" Value="Collapsed"/>
								<Style.Triggers>
									<DataTrigger Binding="{Binding HasCours}" Value="True">
										<Setter Property="Visibility" Value="Visible"/>
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</Grid.Style>

						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="*"/>
						</Grid.RowDefinitions>

						<!-- Bandeau info fichier + actions -->
						<Border Grid.Row="0" Margin="20,16,20,0" CornerRadius="12"
                                Background="#F5F0FF" BorderBrush="#DDD6FE" BorderThickness="1" Padding="16,12">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="Auto"/>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>

								<!-- Icône type fichier -->
								<Border Grid.Column="0" Width="42" Height="42" CornerRadius="10"
                                        Background="White" Margin="0,0,12,0">
									<TextBlock FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center">
										<TextBlock.Style>
											<Style TargetType="TextBlock">
												<Setter Property="Text" Value="📄"/>
												<Style.Triggers>
													<DataTrigger Binding="{Binding TypeFichier}" Value="PDF">
														<Setter Property="Text" Value="📕"/>
													</DataTrigger>
													<DataTrigger Binding="{Binding TypeFichier}" Value="DOCX">
														<Setter Property="Text" Value="📘"/>
													</DataTrigger>
													<DataTrigger Binding="{Binding TypeFichier}" Value="TXT">
														<Setter Property="Text" Value="📃"/>
													</DataTrigger>
												</Style.Triggers>
											</Style>
										</TextBlock.Style>
									</TextBlock>
								</Border>

								<!-- Infos -->
								<StackPanel Grid.Column="1" VerticalAlignment="Center">
									<TextBlock Text="{Binding TitreCours}" FontSize="13" FontWeight="700"
                                               Foreground="#4C1D95" TextTrimming="CharacterEllipsis"/>
									<StackPanel Orientation="Horizontal" Margin="0,4,0,0">
										<Border CornerRadius="4" Padding="6,2" Background="#EDE9FE" Margin="0,0,8,0">
											<TextBlock Text="{Binding TypeFichier}" FontSize="10"
                                                       FontWeight="700" Foreground="#7C3AED"/>
										</Border>
										<TextBlock Text="{Binding NombreCaracteres}" FontSize="11" Foreground="#9CA3AF"/>
									</StackPanel>
								</StackPanel>

								<!-- Boutons action -->
								<StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">

									<!-- Modifier / Verrouiller -->
									<Border CornerRadius="8" Padding="10,7" Margin="0,0,8,0" Cursor="Hand">
										<Border.InputBindings>
											<MouseBinding MouseAction="LeftClick" Command="{Binding ToggleEditionContenuCommand}"/>
										</Border.InputBindings>
										<Border.Style>
											<Style TargetType="Border">
												<Setter Property="Background" Value="#EDE9FE"/>
												<Style.Triggers>
													<Trigger Property="IsMouseOver" Value="True">
														<Setter Property="Background" Value="#DDD6FE"/>
													</Trigger>
													<DataTrigger Binding="{Binding IsEditingContenu}" Value="True">
														<Setter Property="Background" Value="#A855F7"/>
													</DataTrigger>
												</Style.Triggers>
											</Style>
										</Border.Style>
										<TextBlock FontSize="11" FontWeight="600">
											<TextBlock.Style>
												<Style TargetType="TextBlock">
													<Setter Property="Text" Value="✏️ Modifier"/>
													<Setter Property="Foreground" Value="#7C3AED"/>
													<Style.Triggers>
														<DataTrigger Binding="{Binding IsEditingContenu}" Value="True">
															<Setter Property="Text" Value="🔒 Verrouiller"/>
															<Setter Property="Foreground" Value="White"/>
														</DataTrigger>
													</Style.Triggers>
												</Style>
											</TextBlock.Style>
										</TextBlock>
									</Border>

									<!-- Effacer -->
									<Border CornerRadius="8" Padding="10,7" Cursor="Hand">
										<Border.InputBindings>
											<MouseBinding MouseAction="LeftClick" Command="{Binding EffacerContenuCommand}"/>
										</Border.InputBindings>
										<Border.Style>
											<Style TargetType="Border">
												<Setter Property="Background" Value="#FEE2E2"/>
												<Style.Triggers>
													<Trigger Property="IsMouseOver" Value="True">
														<Setter Property="Background" Value="#FECACA"/>
													</Trigger>
												</Style.Triggers>
											</Style>
										</Border.Style>
										<TextBlock Text="🗑️ Effacer" FontSize="11"
                                                   FontWeight="600" Foreground="#DC2626"/>
									</Border>
								</StackPanel>
							</Grid>
						</Border>

						<!-- Zone contenu — lecture seule ou éditable -->
						<Border Grid.Row="1" Margin="20,12,20,20" CornerRadius="12" BorderThickness="1.5">
							<Border.Style>
								<Style TargetType="Border">
									<Setter Property="Background" Value="#FAFAFA"/>
									<Setter Property="BorderBrush" Value="#E8E7E3"/>
									<Style.Triggers>
										<DataTrigger Binding="{Binding IsEditingContenu}" Value="True">
											<Setter Property="Background" Value="White"/>
											<Setter Property="BorderBrush" Value="#A855F7"/>
										</DataTrigger>
									</Style.Triggers>
								</Style>
							</Border.Style>

							<Grid>
								<!-- Badge mode édition -->
								<Border VerticalAlignment="Top" HorizontalAlignment="Right"
                                        Margin="0,10,14,0" CornerRadius="6" Padding="8,4"
                                        Background="#A855F7"
                                        Visibility="{Binding IsEditingContenu, Converter={StaticResource BoolToVis}}">
									<TextBlock Text="Mode édition" FontSize="10" FontWeight="600" Foreground="White"/>
								</Border>

								<ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Padding="16,14">
									<TextBox Text="{Binding ContenuCours, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="12" Foreground="#374151"
                                             BorderThickness="0" Background="Transparent"
                                             TextWrapping="Wrap" AcceptsReturn="True"
                                             FontFamily="Consolas"
                                             CaretBrush="#A855F7"
                                             IsReadOnly="{Binding IsNotEditingContenu}"/>
								</ScrollViewer>
							</Grid>
						</Border>
					</Grid>

				</Grid>
			</Grid>
		</Grid>
	</Grid>
</Window>
