<Window x:Class="smartest_desktop.Views.QuizExamenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:smartest_desktop.ViewModels"
        Title="SmarTest — Quiz et Examens"
        Height="720" Width="1280"
        MinHeight="600" MinWidth="960"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#F8F8F6"
        FontFamily="Segoe UI">

    <Window.DataContext>
        <vm:QuizExamenViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══════════ HEADER ══════════ -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E8E7E3"
                BorderThickness="0,0,0,1"
                Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Flèche retour -->
                <Border Grid.Column="0"
                        Width="36" Height="36"
                        CornerRadius="8"
                        Background="#F0EFE8"
                        Cursor="Hand"
                        Margin="0,0,20,0">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding RetourDashboardCommand}"/>
                    </Border.InputBindings>
                    <TextBlock Text="←" FontSize="18" FontWeight="300"
                               Foreground="#1A1A1A"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Logo + titre -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="8" Height="8" CornerRadius="4" Background="#1A1A1A"
                                VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock FontSize="17" FontWeight="700" Foreground="#1A1A1A">
                            <Run Text="Smar"/>
                            <Run Text="Test" Foreground="#6B6B6B"/>
                        </TextBlock>
                    </StackPanel>
                    <TextBlock Text="Espace professeur" FontSize="11"
                               Foreground="#ABABAB" Margin="16,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════ CONTENU ══════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Sidebar menu gauche identique au Dashboard -->
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── SIDEBAR ── -->
            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#E8E7E3"
                    BorderThickness="0,0,1,0">
                <StackPanel Margin="12,20,12,20">

                    <!-- Tableau de bord -->
                    <Border CornerRadius="10" Padding="14,12" Cursor="Hand" Margin="0,0,0,4">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding RetourDashboardCommand}"/>
                        </Border.InputBindings>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F5F4F0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⊞" FontSize="14" Margin="0,0,10,0"
                                       Foreground="#6B6B6B" VerticalAlignment="Center"/>
                            <TextBlock Text="Tableau de bord" FontSize="13"
                                       Foreground="#6B6B6B" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Mes cours -->
                    <Border CornerRadius="10" Padding="14,12" Cursor="Hand" Margin="0,0,0,4">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F5F4F0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="≡" FontSize="14" Margin="0,0,10,0"
                                       Foreground="#6B6B6B" VerticalAlignment="Center"/>
                            <TextBlock Text="Mes cours" FontSize="13"
                                       Foreground="#6B6B6B" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Quiz et examens — ACTIF -->
                    <Border CornerRadius="10" Padding="14,12" Margin="0,0,0,4"
                            Background="#1A1A1A">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✎" FontSize="14" Margin="0,0,10,0"
                                       Foreground="White" VerticalAlignment="Center"/>
                            <TextBlock Text="Quiz et examens" FontSize="13"
                                       Foreground="White" FontWeight="600"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Sessions actives -->
                    <Border CornerRadius="10" Padding="14,12" Cursor="Hand" Margin="0,0,0,4">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F5F4F0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="○" FontSize="14" Margin="0,0,10,0"
                                       Foreground="#6B6B6B" VerticalAlignment="Center"/>
                            <TextBlock Text="Sessions actives" FontSize="13"
                                       Foreground="#6B6B6B" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Statistiques -->
                    <Border CornerRadius="10" Padding="14,12" Cursor="Hand" Margin="0,0,0,4">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F5F4F0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▦" FontSize="14" Margin="0,0,10,0"
                                       Foreground="#6B6B6B" VerticalAlignment="Center"/>
                            <TextBlock Text="Statistiques" FontSize="13"
                                       Foreground="#6B6B6B" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Paramètres -->
                    <Border CornerRadius="10" Padding="14,12" Cursor="Hand" Margin="0,0,0,4">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F5F4F0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙" FontSize="14" Margin="0,0,10,0"
                                       Foreground="#6B6B6B" VerticalAlignment="Center"/>
                            <TextBlock Text="Paramètres" FontSize="13"
                                       Foreground="#6B6B6B" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>

            <!-- ── CONTENU PRINCIPAL ── -->
            <Grid Grid.Column="1" Background="#F8F8F6">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            MaxWidth="820">

                    <!-- Titre de section -->
                    <TextBlock Text="Quiz et Examens"
                               FontSize="28" FontWeight="700"
                               Foreground="#1A1A1A"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Choisissez le type d'évaluation que vous souhaitez créer"
                               FontSize="14" Foreground="#ABABAB"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,56"/>

                    <!-- Deux cartes côte à côte -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                        <!-- ══ CARTE QUIZ ══ -->
                        <Border Width="340" Margin="0,0,24,0" Cursor="Hand"
                                CornerRadius="20" BorderThickness="2">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding GenererQuizCommand}"/>
                            </Border.InputBindings>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="BorderBrush" Value="#E8E7E3"/>
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect BlurRadius="16"
                                                              Opacity="0.06"
                                                              ShadowDepth="4"
                                                              Direction="270"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="#1A1A1A"/>
                                            <Setter Property="Background" Value="#FAFAF9"/>
                                            <Setter Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect BlurRadius="28"
                                                                      Opacity="0.12"
                                                                      ShadowDepth="6"
                                                                      Direction="270"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <Grid Margin="36,40,36,40">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Icône -->
                                <Border Grid.Row="0"
                                        Width="64" Height="64"
                                        CornerRadius="18"
                                        Background="#1A1A1A"
                                        HorizontalAlignment="Left"
                                        Margin="0,0,0,24">
                                    <TextBlock Text="✨"
                                               FontSize="28"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <!-- Titre -->
                                <TextBlock Grid.Row="1"
                                           Text="Générer un Quiz"
                                           FontSize="20" FontWeight="700"
                                           Foreground="#1A1A1A"
                                           Margin="0,0,0,10"/>

                                <!-- Description -->
                                <TextBlock Grid.Row="2"
                                           Text="Créez un quiz QCM automatiquement à partir d'un de vos cours grâce à l'IA locale Ollama."
                                           FontSize="13" Foreground="#6B6B6B"
                                           TextWrapping="Wrap"
                                           LineHeight="20"
                                           Margin="0,0,0,28"/>

                                <!-- Tags -->
                                <StackPanel Grid.Row="3"
                                            Orientation="Horizontal"
                                            Margin="0,0,0,32">
                                    <Border CornerRadius="6" Padding="8,4"
                                            Background="#F0F9FF" Margin="0,0,6,0">
                                        <TextBlock Text="QCM" FontSize="10" FontWeight="700"
                                                   Foreground="#0369A1"/>
                                    </Border>
                                    <Border CornerRadius="6" Padding="8,4"
                                            Background="#F0FDF4" Margin="0,0,6,0">
                                        <TextBlock Text="IA locale" FontSize="10" FontWeight="700"
                                                   Foreground="#16A34A"/>
                                    </Border>
                                    <Border CornerRadius="6" Padding="8,4"
                                            Background="#FFF7ED">
                                        <TextBlock Text="Ollama" FontSize="10" FontWeight="700"
                                                   Foreground="#C2410C"/>
                                    </Border>
                                </StackPanel>

                                <!-- Bouton -->
                                <Border Grid.Row="4"
                                        CornerRadius="10"
                                        Background="#1A1A1A"
                                        Padding="0,14">
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center">
                                        <TextBlock Text="Générer un Quiz"
                                                   FontSize="13" FontWeight="600"
                                                   Foreground="White"/>
                                        <TextBlock Text=" →"
                                                   FontSize="13" FontWeight="600"
                                                   Foreground="#888888"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- ══ CARTE EXAMEN ══ -->
                        <Border Width="340" Cursor="Hand"
                                CornerRadius="20" BorderThickness="2">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding GenererExamenCommand}"/>
                            </Border.InputBindings>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="BorderBrush" Value="#E8E7E3"/>
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect BlurRadius="16"
                                                              Opacity="0.06"
                                                              ShadowDepth="4"
                                                              Direction="270"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="#1A1A1A"/>
                                            <Setter Property="Background" Value="#FAFAF9"/>
                                            <Setter Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect BlurRadius="28"
                                                                      Opacity="0.12"
                                                                      ShadowDepth="6"
                                                                      Direction="270"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <Grid Margin="36,40,36,40">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Icône -->
                                <Border Grid.Row="0"
                                        Width="64" Height="64"
                                        CornerRadius="18"
                                        Background="#1A1A1A"
                                        HorizontalAlignment="Left"
                                        Margin="0,0,0,24">
                                    <TextBlock Text="📋"
                                               FontSize="28"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <!-- Titre -->
                                <TextBlock Grid.Row="1"
                                           Text="Créer un Examen"
                                           FontSize="20" FontWeight="700"
                                           Foreground="#1A1A1A"
                                           Margin="0,0,0,10"/>

                                <!-- Description -->
                                <TextBlock Grid.Row="2"
                                           Text="Créez un examen multi-types (QCM, cases à cocher, rédaction, images) à partir de vos cours grâce à Ollama."
                                           FontSize="13" Foreground="#6B6B6B"
                                           TextWrapping="Wrap"
                                           LineHeight="20"
                                           Margin="0,0,0,28"/>

                                <!-- Tags -->
                                <StackPanel Grid.Row="3"
                                            Orientation="Horizontal"
                                            Margin="0,0,0,32">
                                    <Border CornerRadius="6" Padding="8,4"
                                            Background="#F5F3FF" Margin="0,0,6,0">
                                        <TextBlock Text="Multi-types" FontSize="10" FontWeight="700"
                                                   Foreground="#7C3AED"/>
                                    </Border>
                                    <Border CornerRadius="6" Padding="8,4"
                                            Background="#F0FDF4" Margin="0,0,6,0">
                                        <TextBlock Text="IA locale" FontSize="10" FontWeight="700"
                                                   Foreground="#16A34A"/>
                                    </Border>
                                    <Border CornerRadius="6" Padding="8,4"
                                            Background="#FFF7ED">
                                        <TextBlock Text="Ollama" FontSize="10" FontWeight="700"
                                                   Foreground="#C2410C"/>
                                    </Border>
                                </StackPanel>

                                <!-- Bouton -->
                                <Border Grid.Row="4"
                                        CornerRadius="10"
                                        Background="#1A1A1A"
                                        Padding="0,14">
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center">
                                        <TextBlock Text="Créer un Examen"
                                                   FontSize="13" FontWeight="600"
                                                   Foreground="White"/>
                                        <TextBlock Text=" →"
                                                   FontSize="13" FontWeight="600"
                                                   Foreground="#888888"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>

    