<Window x:Class="smartest_desktop.Views.QuizExamenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:smartest_desktop.ViewModels"
        Title="SmarTest — Quiz et Examens"
        Height="720" Width="1280"
        MinHeight="600" MinWidth="960"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#fafbfd"
        FontFamily="Segoe UI">

	<Window.DataContext>
		<vm:QuizExamenViewModel />
	</Window.DataContext>

	<Window.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary Source="/Views/Styles/StylesGlobal.xaml"/>
			</ResourceDictionary.MergedDictionaries>

			<!-- Badge statut Quiz -->
			<Style x:Key="BadgeBrouillon" TargetType="Border">
				<Setter Property="Background" Value="#fff7ed"/>
				<Setter Property="CornerRadius" Value="6"/>
				<Setter Property="Padding" Value="6,5"/>
			</Style>
			<Style x:Key="BadgePublie" TargetType="Border">
				<Setter Property="Background" Value="#eaf3de"/>
				<Setter Property="CornerRadius" Value="6"/>
				<Setter Property="Padding" Value="6,5"/>
			</Style>
			<Style x:Key="BadgePlanifie" TargetType="Border">
				<Setter Property="Background" Value="#eef3fd"/>
				<Setter Property="CornerRadius" Value="6"/>
				<Setter Property="Padding" Value="6,5"/>
			</Style>

			<!-- Bouton action table -->
			<Style x:Key="ActionBtn" TargetType="Button">
				<Setter Property="Height" Value="30"/>
				<Setter Property="MinWidth" Value="58"/>
				<Setter Property="Padding" Value="10,5"/>
				<Setter Property="FontSize" Value="11"/>
				<Setter Property="FontWeight" Value="600"/>
				<Setter Property="BorderThickness" Value="0"/>
				<Setter Property="Cursor" Value="Hand"/>
				<Setter Property="Template">
					<Setter.Value>
						<ControlTemplate TargetType="Button">
							<Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
									Padding="{TemplateBinding Padding}"
                                    CornerRadius="6">
								<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
							</Border>
							<ControlTemplate.Triggers>
								<Trigger Property="IsMouseOver" Value="True">
									<Setter Property="Opacity" Value="0.85"/>
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>

		</ResourceDictionary>
	</Window.Resources>

	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="230"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>

		<!-- ══ SIDEBAR ══ -->
		<Border Grid.Column="0" Background="White"
                BorderBrush="#e2e8f4" BorderThickness="0,0,1,0">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>

				<StackPanel Grid.Row="0" Margin="22,28,22,32">
					<StackPanel Orientation="Horizontal">
						<Ellipse Width="8" Height="8" Fill="#4f8ef7"
                                 VerticalAlignment="Center" Margin="0,0,8,0"/>
						<TextBlock FontFamily="Georgia" FontSize="18" FontWeight="Bold"
                                   Foreground="#0f1e3d" VerticalAlignment="Center">
							Smar<Run Foreground="#4f8ef7">Test</Run>
						</TextBlock>
					</StackPanel>
					<TextBlock Text="Espace professeur" FontSize="11" Foreground="#8899b8" Margin="16,5,0,0"/>
				</StackPanel>

				<StackPanel Grid.Row="1" Margin="12,0">
					<Border Style="{StaticResource MenuPopupItem}" Margin="0,1">
						<Border.InputBindings>
							<MouseBinding MouseAction="LeftClick" Command="{Binding RetourDashboardCommand}"/>
						</Border.InputBindings>
						<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
							<TextBlock Text="&#xE80F;" FontSize="13" Foreground="#6b7a99"
                                       FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
							<TextBlock Text="Home" FontSize="13" Foreground="#0f1e3d"/>
						</StackPanel>
					</Border>

					<Border CornerRadius="8" Height="40" Padding="14,0" Background="#0f1e3d" Margin="0,1">
						<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
							<TextBlock Text="&#xE9D5;" FontSize="13" Foreground="White"
                                       FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
							<TextBlock Text="Quiz et examens" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
						</StackPanel>
					</Border>

					<Border Style="{StaticResource MenuPopupItem}" Margin="0,1">
						<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
							<TextBlock Text="&#xE7FC;" FontSize="13" Foreground="#6b7a99"
                                       FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
							<TextBlock Text="Sessions actives" FontSize="13" Foreground="#0f1e3d"/>
						</StackPanel>
					</Border>

					<Border Style="{StaticResource MenuPopupItem}" Margin="0,1">
						<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
							<TextBlock Text="&#xE9D2;" FontSize="13" Foreground="#6b7a99"
                                       FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
							<TextBlock Text="Statistiques" FontSize="13" Foreground="#0f1e3d"/>
						</StackPanel>
					</Border>

					<Border Style="{StaticResource MenuPopupItem}" Margin="0,1">
						<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
							<TextBlock Text="&#xE713;" FontSize="13" Foreground="#6b7a99"
                                       FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
							<TextBlock Text="Paramètres" FontSize="13" Foreground="#0f1e3d"/>
						</StackPanel>
					</Border>
				</StackPanel>

				<StackPanel Grid.Row="2" Margin="12,0,12,18">
					<Border Background="#f0f3f9" CornerRadius="10" BorderBrush="#e2e8f4"
                            BorderThickness="1" Padding="8,6" Margin="0,0,0,8">
						<StackPanel>
							<StackPanel Orientation="Horizontal" Margin="0,0,0,3">
								<Ellipse Width="7" Height="7" Fill="#16a34a"
                                         VerticalAlignment="Center" Margin="0,0,7,0"/>
								<TextBlock Text="{Binding Nom}" FontSize="13" FontWeight="600" Foreground="#0f1e3d"/>
							</StackPanel>
							<TextBlock Text="{Binding Email}" FontSize="11" Foreground="#8899b8" Margin="14,0,0,0"/>
						</StackPanel>
					</Border>
					<Border Style="{StaticResource MenuPopupItem}" Margin="0,2">
						<Border.InputBindings>
							<MouseBinding MouseAction="LeftClick" Command="{Binding LogoutCommand}"/>
						</Border.InputBindings>
						<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
							<TextBlock Text="&#xF3B1;" FontSize="13" Foreground="#dc2626"
                                       FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
							<TextBlock Text="Déconnexion" FontSize="13" Foreground="#dc2626"/>
						</StackPanel>
					</Border>
				</StackPanel>
			</Grid>
		</Border>

		<!-- ══ MAIN CONTENT ══ -->
		<Grid Grid.Column="1">
			<Grid.RowDefinitions>
				<RowDefinition Height="*"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

			<ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Background="white">
				<StackPanel Margin="40,36,40,40">

					<!-- Header -->
					<StackPanel Margin="0,0,0,28">
						<TextBlock Text="Mes évaluations" FontSize="22" FontWeight="700" Foreground="#0f1e3d"/>
					</StackPanel>

					<!-- Cartes action -->
					<UniformGrid Columns="2" Margin="0,0,0,36">
						<Border Margin="0,0,8,0" Cursor="Hand" CornerRadius="14"
                                BorderThickness="1.5" Background="White">
							<Border.InputBindings>
								<MouseBinding MouseAction="LeftClick" Command="{Binding GenererQuizCommand}"/>
							</Border.InputBindings>
							<Border.Effect>
								<DropShadowEffect BlurRadius="12" Opacity="0.05" ShadowDepth="3" Direction="270"/>
							</Border.Effect>
							<Border.Style>
								<Style TargetType="Border">
									<Setter Property="BorderBrush" Value="#e2e8f4"/>
									<Style.Triggers>
										<Trigger Property="IsMouseOver" Value="True">
											<Setter Property="BorderBrush" Value="#0f1e3d"/>
										</Trigger>
									</Style.Triggers>
								</Style>
							</Border.Style>
							<Grid Margin="22,20,22,20">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="Auto"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>
								<Border Width="42" Height="42" CornerRadius="10" Background="#0f1e3d"
                                        Margin="0,0,16,0" VerticalAlignment="Center">
									<TextBlock Text="&#xE9D5;" FontSize="18" Foreground="White"
                                               FontFamily="Segoe MDL2 Assets"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
								</Border>
								<StackPanel Grid.Column="1" VerticalAlignment="Center">
									<TextBlock Text="Générer un quiz" FontSize="14" FontWeight="700" Foreground="#0f1e3d" Margin="0,0,0,4"/>
									<TextBlock Text="QCM depuis un cours importé"
                                               FontSize="12" Foreground="#8899b8" TextWrapping="Wrap"/>
								</StackPanel>
							</Grid>
						</Border>

						<Border Margin="8,0,0,0" Cursor="Hand" CornerRadius="14"
                                BorderThickness="1.5" Background="White">
							<Border.InputBindings>
								<MouseBinding MouseAction="LeftClick" Command="{Binding GenererExamenCommand}"/>
							</Border.InputBindings>
							<Border.Effect>
								<DropShadowEffect BlurRadius="12" Opacity="0.05" ShadowDepth="3" Direction="270"/>
							</Border.Effect>
							<Border.Style>
								<Style TargetType="Border">
									<Setter Property="BorderBrush" Value="#e2e8f4"/>
									<Style.Triggers>
										<Trigger Property="IsMouseOver" Value="True">
											<Setter Property="BorderBrush" Value="#0f1e3d"/>
										</Trigger>
									</Style.Triggers>
								</Style>
							</Border.Style>
							<Grid Margin="22,20,22,20">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="Auto"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>
								<Border Width="42" Height="42" CornerRadius="10" Background="#0f1e3d"
                                        Margin="0,0,16,0" VerticalAlignment="Center">
									<TextBlock Text="&#xE9D2;" FontSize="18" Foreground="White"
                                               FontFamily="Segoe MDL2 Assets"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
								</Border>
								<StackPanel Grid.Column="1" VerticalAlignment="Center">
									<TextBlock Text="Créer un examen" FontSize="14" FontWeight="700" Foreground="#0f1e3d" Margin="0,0,0,4"/>
									<TextBlock Text="Types variés depuis un cours importé"
                                               FontSize="12" Foreground="#8899b8" TextWrapping="Wrap"/>
								</StackPanel>
							</Grid>
						</Border>
					</UniformGrid>

					<!-- ══ MES QUIZ ══ -->
					<Border Style="{StaticResource DashCard}" Padding="24,20" Margin="0,0,0,20">
						<StackPanel>

							<!-- Titre + recherche -->
							<Grid Margin="0,0,0,16">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="280"/>
								</Grid.ColumnDefinitions>
								<StackPanel Grid.Column="0">
									<TextBlock Text="Mes Quiz" FontSize="15" FontWeight="600" Foreground="#0f1e3d"/>
									<TextBlock FontSize="12" Foreground="#8899b8" Margin="0,3,0,0" TextWrapping="Wrap">
										<Run Text="{Binding TotalQuiz, Mode=OneWay}"/>
										<Run Text=" quiz enregistrés"/>
									</TextBlock>
								</StackPanel>
								<StackPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="12,0,0,0">
									<TextBlock Text="Rechercher" FontSize="11" FontWeight="600" Foreground="#8899b8" Margin="0,0,0,4"/>
									<TextBox Text="{Binding FiltreQuiz, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="6,5" FontSize="11"
                                         BorderBrush="#e2e8f4" BorderThickness="1"
                                         Background="White" VerticalContentAlignment="Center">
										<TextBox.Resources>
											<Style TargetType="Border">
												<Setter Property="CornerRadius" Value="8"/>
											</Style>
										</TextBox.Resources>
									</TextBox>
								</StackPanel>
							</Grid>

							<Border Height="1" Background="#e2e8f4" Margin="0,0,0,0"/>

							<!-- En-têtes colonnes (masqués si liste vide) -->
							<Grid Margin="0,12,0,8"
                                  Visibility="{Binding AfficherListeQuiz, Converter={StaticResource BoolToVis}}">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="100"/>
									<ColumnDefinition Width="90"/>
									<ColumnDefinition Width="80"/>
									<ColumnDefinition Width="180"/>
								</Grid.ColumnDefinitions>
								<TextBlock Grid.Column="0" Text="Titre" FontSize="11" FontWeight="600" Foreground="#8899b8"/>
								<TextBlock Grid.Column="1" Text="Difficulté" FontSize="11" FontWeight="600" Foreground="#8899b8"/>
								<TextBlock Grid.Column="2" Text="Questions" FontSize="11" FontWeight="600" Foreground="#8899b8"/>
								<TextBlock Grid.Column="3" Text="Statut" FontSize="11" FontWeight="600" Foreground="#8899b8"/>
								<TextBlock Grid.Column="4" Text="Actions" FontSize="11" FontWeight="600" Foreground="#8899b8"/>
							</Grid>
							<Border Height="1" Background="#f0f3f9" Margin="0,0,0,4"
                                    Visibility="{Binding AfficherListeQuiz, Converter={StaticResource BoolToVis}}"/>

							<!-- Liste quiz (page courante) -->
							<ItemsControl ItemsSource="{Binding QuizPage}"
                                          Visibility="{Binding AfficherListeQuiz, Converter={StaticResource BoolToVis}}">
								<ItemsControl.ItemTemplate>
									<DataTemplate>
										<Border Padding="0,10" BorderBrush="#f0f3f9" BorderThickness="0,0,0,1">
											<Grid>
												<Grid.ColumnDefinitions>
													<ColumnDefinition Width="*"/>
													<ColumnDefinition Width="100"/>
													<ColumnDefinition Width="90"/>
													<ColumnDefinition Width="80"/>
													<ColumnDefinition Width="180"/>
												</Grid.ColumnDefinitions>

												<StackPanel Grid.Column="0" VerticalAlignment="Center">
													<TextBlock Text="{Binding TitreAffiche}" FontSize="13"
                                                               FontWeight="600" Foreground="#0f1e3d"
                                                               Cursor="Hand" >
														<TextBlock.InputBindings>
															<MouseBinding MouseAction="LeftClick"
																		  Command="{Binding DataContext.OuvrirQuizCommand, RelativeSource={RelativeSource AncestorType=Window}}"
																		  CommandParameter="{Binding}"/>
														</TextBlock.InputBindings>
													</TextBlock>
													<TextBlock Text="{Binding Quiz.CoursSourceTitre}" FontSize="11"
                                                               Foreground="#8899b8" Margin="0,2,0,0"/>
												</StackPanel>

												<TextBlock Grid.Column="1" Text="{Binding Quiz.Difficulte}"
                                                           FontSize="12" Foreground="#6b7a99"
                                                           VerticalAlignment="Center"/>

												<TextBlock Grid.Column="2" Text="{Binding Quiz.NombreQuestions}"
                                                           FontSize="12" Foreground="#6b7a99"
                                                           VerticalAlignment="Center"/>

												<!-- Badge statut -->
												<Border Grid.Column="3" CornerRadius="6" Padding="8,3"
                                                        VerticalAlignment="Center" HorizontalAlignment="Left">
													<Border.Style>
														<Style TargetType="Border">
															<Setter Property="Background" Value="#fff7ed"/>
															<Style.Triggers>
																<DataTrigger Binding="{Binding Quiz.Statut}" Value="Publié">
																	<Setter Property="Background" Value="#eaf3de"/>
																</DataTrigger>
																<DataTrigger Binding="{Binding Quiz.Statut}" Value="Validé">
																	<Setter Property="Background" Value="#eef3fd"/>
																</DataTrigger>
															</Style.Triggers>
														</Style>
													</Border.Style>
													<TextBlock FontSize="10" FontWeight="700">
														<TextBlock.Style>
															<Style TargetType="TextBlock">
																<Setter Property="Text" Value="{Binding Quiz.Statut}"/>
																<Setter Property="Foreground" Value="#c2410c"/>
																<Style.Triggers>
																<DataTrigger Binding="{Binding Quiz.Statut}" Value="Publié">
																	<Setter Property="Foreground" Value="#16a34a"/>
																</DataTrigger>
																<DataTrigger Binding="{Binding Quiz.Statut}" Value="Validé">
																	<Setter Property="Foreground" Value="#4f8ef7"/>
																</DataTrigger>
																</Style.Triggers>
															</Style>
														</TextBlock.Style>
													</TextBlock>
												</Border>

												<!-- Actions -->
												<StackPanel Grid.Column="4" Orientation="Horizontal"
                                                            VerticalAlignment="Center">
													<Button Style="{StaticResource ActionBtn}"
                                                            Background="#eef3fd" BorderBrush="#eef3fd"
                                                            Foreground="#4f8ef7" Margin="0,0,6,0"
                                                            Command="{Binding DataContext.PublierQuizCommand,
                                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}">
														<TextBlock Text="Publier"/>
													</Button>
													<Button Style="{StaticResource ActionBtn}"
                                                            Background="#fcebeb" BorderBrush="#fcebeb"
                                                            Foreground="#dc2626"
                                                            Command="{Binding DataContext.SupprimerQuizCommand,
                                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}">
														<TextBlock Text="Supprimer"/>
													</Button>
												</StackPanel>

											</Grid>
										</Border>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>

							<!-- Pagination quiz -->
							<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0"
                                        Visibility="{Binding AfficherListeQuiz, Converter={StaticResource BoolToVis}}">
								<Button Style="{StaticResource ActionBtn}" Background="#f0f3f9" Foreground="#0f1e3d"
                                        Margin="0,0,8,0" MinWidth="25" Padding="3,2"
                                        Command="{Binding QuizPagePrecedenteCommand}">
									<TextBlock Text="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
								</Button>
								<TextBlock Text="{Binding LibellePaginationQuiz}" VerticalAlignment="Center"
                                           FontSize="12" FontWeight="600" Foreground="#6b7a99" Margin="8,0"/>
								<Button Style="{StaticResource ActionBtn}" Background="#f0f3f9" Foreground="#0f1e3d"
                                        Margin="8,0,0,0" MinWidth="25" Padding="3,2"
                                        Command="{Binding QuizPageSuivanteCommand}">
									<TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
								</Button>
							</StackPanel>

							<!-- État vide quiz -->
							<StackPanel HorizontalAlignment="Center" Margin="0,20"
                                        Visibility="{Binding HasNoQuiz, Converter={StaticResource BoolToVis}}">
								<TextBlock Text="Aucun quiz créé pour le moment"
                                           FontSize="13" Foreground="#8899b8" HorizontalAlignment="Center"/>
							</StackPanel>
							<StackPanel HorizontalAlignment="Center" Margin="0,20"
                                        Visibility="{Binding HasNoQuizRecherche, Converter={StaticResource BoolToVis}}">
								<TextBlock Text="Aucun quiz ne correspond à la recherche"
                                           FontSize="13" Foreground="#8899b8" HorizontalAlignment="Center"/>
							</StackPanel>

						</StackPanel>
					</Border>

					<!-- ══ MES EXAMENS ══ -->
					<Border Style="{StaticResource DashCard}" Padding="24,20">
						<StackPanel>

							<Grid Margin="0,0,0,16">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="280"/>
								</Grid.ColumnDefinitions>
								<StackPanel Grid.Column="0">
									<TextBlock Text="Mes Examens" FontSize="15" FontWeight="600" Foreground="#0f1e3d"/>
									<TextBlock FontSize="12" Foreground="#8899b8" Margin="0,3,0,0" TextWrapping="Wrap">
										<Run Text="{Binding TotalExamens, Mode=OneWay}"/>
										<Run Text="examens enregistrés"/>
									</TextBlock>
								</StackPanel>
								<StackPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="12,0,0,0">
									<TextBlock Text="Rechercher" FontSize="11" FontWeight="600" Foreground="#8899b8" Margin="0,0,0,4"/>
									<TextBox Text="{Binding FiltreExamen, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="6,5" FontSize="11"
                                         BorderBrush="#e2e8f4" BorderThickness="1"
                                         Background="White" VerticalContentAlignment="Center">
										<TextBox.Resources>
											<Style TargetType="Border">
												<Setter Property="CornerRadius" Value="8"/>
											</Style>
										</TextBox.Resources>
									</TextBox>
								</StackPanel>
							</Grid>

							<Border Height="1" Background="#e2e8f4" Margin="0,0,0,0"/>

							<!-- En-têtes -->
							<Grid Margin="0,12,0,8"
                                  Visibility="{Binding AfficherListeExamens, Converter={StaticResource BoolToVis}}">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="80"/>
									<ColumnDefinition Width="100"/>
									<ColumnDefinition Width="90"/>
									<ColumnDefinition Width="200"/>
								</Grid.ColumnDefinitions>
								<TextBlock Grid.Column="0" Text="Titre" FontSize="11" FontWeight="600" Foreground="#8899b8"/>
								<TextBlock Grid.Column="1" Text="Durée" FontSize="11" FontWeight="600" Foreground="#8899b8"/>
								<TextBlock Grid.Column="2" Text="Date prévue" FontSize="11" FontWeight="600" Foreground="#8899b8"/>
								<TextBlock Grid.Column="3" Text="Statut" FontSize="11" FontWeight="600" Foreground="#8899b8"/>
								<TextBlock Grid.Column="4" Text="Actions" FontSize="11" FontWeight="600" Foreground="#8899b8"/>
							</Grid>

							<Border Height="1" Background="#f0f3f9" Margin="0,0,0,4"
                                    Visibility="{Binding AfficherListeExamens, Converter={StaticResource BoolToVis}}"/>

							<!-- Liste examens (page courante) -->
							<ItemsControl ItemsSource="{Binding ExamensPage}"
                                          Visibility="{Binding AfficherListeExamens, Converter={StaticResource BoolToVis}}">
								<ItemsControl.ItemTemplate>
									<DataTemplate>
										<Border Padding="0,10" BorderBrush="#f0f3f9" BorderThickness="0,0,0,1">
											<Grid>
												<Grid.ColumnDefinitions>
													<ColumnDefinition Width="*"/>
													<ColumnDefinition Width="80"/>
													<ColumnDefinition Width="100"/>
													<ColumnDefinition Width="90"/>
													<ColumnDefinition Width="200"/>
												</Grid.ColumnDefinitions>

												<TextBlock Grid.Column="0" Text="{Binding TitreAffiche}"
                                                           FontSize="13" FontWeight="600"
                                                           Foreground="#0f1e3d" VerticalAlignment="Center"
                                                           Cursor="Hand" >
													<TextBlock.InputBindings>
														<MouseBinding MouseAction="LeftClick"
																	  Command="{Binding DataContext.OuvrirExamenCommand, RelativeSource={RelativeSource AncestorType=Window}}"
																	  CommandParameter="{Binding}"/>
													</TextBlock.InputBindings>
												</TextBlock>

												<TextBlock Grid.Column="1" FontSize="12"
                                                           Foreground="#6b7a99" VerticalAlignment="Center">
													<Run Text="{Binding Examen.Duree}"/>
													<Run Text=" min"/>
												</TextBlock>

												<TextBlock Grid.Column="2" FontSize="12"
                                                           Foreground="#6b7a99" VerticalAlignment="Center">
													<TextBlock.Style>
														<Style TargetType="TextBlock">
															<Setter Property="Text" Value="Non définie"/>
															<Style.Triggers>
																<DataTrigger Binding="{Binding Examen.DatePrevue}" Value="{x:Null}">
																	<Setter Property="Text" Value="Non définie"/>
																</DataTrigger>
															</Style.Triggers>
														</Style>
													</TextBlock.Style>
												</TextBlock>

												<!-- Badge statut -->
												<Border Grid.Column="3" CornerRadius="6" Padding="8,3"
                                                        VerticalAlignment="Center" HorizontalAlignment="Left">
													<Border.Style>
														<Style TargetType="Border">
															<Setter Property="Background" Value="#fff7ed"/>
															<Style.Triggers>
																<DataTrigger Binding="{Binding Examen.Statut}" Value="PUBLIE">
																	<Setter Property="Background" Value="#eef3fd"/>
																</DataTrigger>
																<DataTrigger Binding="{Binding Examen.Statut}" Value="EN_COURS">
																	<Setter Property="Background" Value="#eaf3de"/>
																</DataTrigger>
																<DataTrigger Binding="{Binding Examen.Statut}" Value="TERMINE">
																	<Setter Property="Background" Value="#f0f3f9"/>
																</DataTrigger>
															</Style.Triggers>
														</Style>
													</Border.Style>
													<TextBlock FontSize="10" FontWeight="700">
														<TextBlock.Style>
															<Style TargetType="TextBlock">
																<Setter Property="Text" Value="{Binding Examen.Statut}"/>
																<Setter Property="Foreground" Value="#c2410c"/>
																<Style.Triggers>
																	<DataTrigger Binding="{Binding Examen.Statut}" Value="PUBLIE">
																		<Setter Property="Foreground" Value="#4f8ef7"/>
																	</DataTrigger>
																	<DataTrigger Binding="{Binding Examen.Statut}" Value="EN_COURS">
																		<Setter Property="Foreground" Value="#16a34a"/>
																	</DataTrigger>
																	<DataTrigger Binding="{Binding Examen.Statut}" Value="TERMINE">
																		<Setter Property="Foreground" Value="#8899b8"/>
																	</DataTrigger>
																</Style.Triggers>
															</Style>
														</TextBlock.Style>
													</TextBlock>
												</Border>

												<!-- Actions -->
												<StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
													<Button Style="{StaticResource ActionBtn}"
                                                            Background="#eaf3de" BorderBrush="#eaf3de"
                                                            Foreground="#16a34a" Margin="0,0,6,0"
                                                            Command="{Binding DataContext.LancerExamenCommand,
                                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}">
														<TextBlock Text="Lancer"/>
													</Button>
													<Button Style="{StaticResource ActionBtn}"
                                                            Background="#fcebeb" BorderBrush="#fcebeb"
                                                            Foreground="#dc2626"
                                                            Command="{Binding DataContext.SupprimerExamenCommand,
                                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}">
														<TextBlock Text="Supprimer"/>
													</Button>
												</StackPanel>

											</Grid>
										</Border>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>

							<!-- Pagination examens -->
							<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0"
                                        Visibility="{Binding AfficherListeExamens, Converter={StaticResource BoolToVis}}">
								<Button Style="{StaticResource ActionBtn}" Background="#f0f3f9" Foreground="#0f1e3d"
                                        Margin="0,0,8,0" MinWidth="25" Padding="3,2"
                                        Command="{Binding ExamenPagePrecedenteCommand}">
									<TextBlock Text="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
								</Button>
								<TextBlock Text="{Binding LibellePaginationExamen}" VerticalAlignment="Center"
                                           FontSize="12" FontWeight="600" Foreground="#6b7a99" Margin="8,0"/>
								<Button Style="{StaticResource ActionBtn}" Background="#f0f3f9" Foreground="#0f1e3d"
                                        Margin="8,0,0,0" MinWidth="25" Padding="3,2"
                                        Command="{Binding ExamenPageSuivanteCommand}">
									<TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
								</Button>
							</StackPanel>

							<!-- État vide examens -->
							<StackPanel HorizontalAlignment="Center" Margin="0,20"
                                        Visibility="{Binding HasNoExamens, Converter={StaticResource BoolToVis}}">
								<TextBlock Text="Aucun examen créé pour le moment"
                                           FontSize="13" Foreground="#8899b8" HorizontalAlignment="Center"/>
							</StackPanel>
							<StackPanel HorizontalAlignment="Center" Margin="0,20"
                                        Visibility="{Binding HasNoExamensRecherche, Converter={StaticResource BoolToVis}}">
								<TextBlock Text="Aucun examen ne correspond à la recherche"
                                           FontSize="13" Foreground="#8899b8" HorizontalAlignment="Center"/>
							</StackPanel>

						</StackPanel>
					</Border>

				</StackPanel>
			</ScrollViewer>

			<!-- Footer -->
			<Border Grid.Row="1" Background="White" BorderBrush="#e2e8f4" BorderThickness="0,1,0,0" Padding="18,14">
				<TextBlock Text="SmarTest — ENSA Oujda · Génie Informatique · 2025–2026"
                           FontSize="11" Foreground="#aab4cc"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
			</Border>

		</Grid>
	</Grid>
</Window>
