<Window x:Class="smartest_desktop.Views.EmailVerificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmarTest — Vérification Email"
        Height="600" Width="900"
        MinHeight="500" MinWidth="700"
        ResizeMode="CanResize"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#f0f3f9">

	<Window.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary Source="/Views/Styles/AuthStyles.xaml"/>
			</ResourceDictionary.MergedDictionaries>
		</ResourceDictionary>
	</Window.Resources>

	<Grid Background="#f0f3f9">

		<Border Style="{StaticResource MainCard}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
			<Border.Effect>
				<DropShadowEffect Color="#000000" Opacity="0.07"
                                  BlurRadius="24" ShadowDepth="3"/>
			</Border.Effect>

			<StackPanel>

				<TextBlock Text="SmarTest" Style="{StaticResource BrandTitle}"/>
				<TextBlock Text="PLATEFORME D'ÉVALUATION" Style="{StaticResource BrandSub}"/>

				<Border Style="{StaticResource IconRing}">
					<TextBlock Text="✉" FontSize="30"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#1a2e5a"/>
				</Border>

				<TextBlock Text="Code de vérification envoyé !" FontFamily="Georgia" FontSize="18"
                           Foreground="#0f1e3d" HorizontalAlignment="Center"/>
				<Border Style="{StaticResource AccentLine}"/>

				<TextBlock FontSize="12" Foreground="#6b7a99" TextWrapping="Wrap"
                           TextAlignment="Center" HorizontalAlignment="Center"
                           Margin="0,0,0,20">
					Un code à 6 chiffres a été envoyé à
					<Run Text="{Binding Email}" FontWeight="SemiBold" Foreground="#1a2e5a"/>.
					Saisissez-le ci-dessous pour activer votre compte.
				</TextBlock>

				<TextBlock Text="Code de vérification" Style="{StaticResource FieldLabel}"/>
				<TextBox Height="50" FontSize="24" FontWeight="Bold"
                         TextAlignment="Center" MaxLength="6"
                         Style="{StaticResource InputBox}"
                         Text="{Binding Code, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,4"/>
				<TextBlock Text="Entrez le code à 6 chiffres reçu par email"
                           FontSize="11" Foreground="#8899b8"
                           HorizontalAlignment="Center" Margin="0,0,0,16"/>

				<Border Style="{StaticResource AlertSuccess}"
                        Visibility="{Binding HasSuccess, Converter={StaticResource BoolToVis}}">
					<TextBlock Text="{Binding SuccessMessage}" Foreground="#27500a"
                               FontSize="12" TextWrapping="Wrap"/>
				</Border>

				<Border Style="{StaticResource AlertError}"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
					<TextBlock Text="{Binding ErrorMessage}" Foreground="#791f1f"
                               FontSize="12" TextWrapping="Wrap"/>
				</Border>

				<Button Style="{StaticResource PrimaryBtn}"
                        Command="{Binding VerifyCommand}"
                        Margin="0,0,0,10">
					<TextBlock>
						<TextBlock.Style>
							<Style TargetType="TextBlock">
								<Setter Property="Text" Value="Vérifier mon email"/>
								<Style.Triggers>
									<DataTrigger Binding="{Binding IsLoading}" Value="True">
										<Setter Property="Text" Value="Vérification en cours..."/>
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</TextBlock.Style>
					</TextBlock>
				</Button>

				<Button Style="{StaticResource SecondaryBtn}"
                        Command="{Binding ResendEmailCommand}">
					<TextBlock>
						<TextBlock.Style>
							<Style TargetType="TextBlock">
								<Setter Property="Text" Value="Renvoyer le code"/>
								<Style.Triggers>
									<DataTrigger Binding="{Binding IsLoading}" Value="True">
										<Setter Property="Text" Value="Envoi en cours..."/>
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</TextBlock.Style>
					</TextBlock>
				</Button>

				<TextBlock Text="SmarTest — ENSA Oujda" Style="{StaticResource FooterText}"/>

			</StackPanel>
		</Border>
	</Grid>
</Window>
