<Window x:Class="smartest_desktop.Views.ResetPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:smartest_desktop.ViewModels"
        Title="SmarTest — Réinitialisation du mot de passe"
        Height="600" Width="900"
        MinHeight="500" MinWidth="700"
        ResizeMode="CanResize"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6">

    <Window.DataContext>
        <vm:ResetPasswordViewModel />
    </Window.DataContext>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Background="#F3F4F6">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Width="480"
                      MaxHeight="700">
            <Border Background="White" CornerRadius="12" Padding="40">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="20" ShadowDepth="4"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="SmarTest" FontSize="26" FontWeight="Bold" Foreground="#1a2e5a" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="Nouveau mot de passe" FontSize="13" Foreground="#6B7280" HorizontalAlignment="Center" Margin="0,0,0,24"/>
                    <Border Background="#F0FDF4" BorderBrush="#BBF7D0" BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,0,0,12" Visibility="{Binding HasSuccess, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding SuccessMessage}" Foreground="#16A34A" FontSize="12" TextWrapping="Wrap"/>
                    </Border>
                    <Border Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,0,0,12" Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626" FontSize="12" TextWrapping="Wrap"/>
                    </Border>
                    <TextBlock Text="Code de réinitialisation" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                    <TextBox Height="40" Padding="10,0" FontSize="13" BorderBrush="#D1D5DB" BorderThickness="1" VerticalContentAlignment="Center" Text="{Binding Token, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                    <TextBlock Text="Copiez le code reçu par email" FontSize="11" Foreground="#9CA3AF" Margin="0,0,0,14"/>
                    <TextBlock Text="Nouveau mot de passe" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="PasswordBox" Height="40" Padding="10,0" FontSize="13" BorderBrush="#D1D5DB" BorderThickness="1" VerticalContentAlignment="Center" PasswordChanged="PasswordBox_Changed" Margin="0,0,0,4"/>
                    <TextBlock Text="Min 8 car., 1 majuscule, 1 chiffre, 1 spécial" FontSize="11" Foreground="#9CA3AF" Margin="0,0,0,14"/>
                    <TextBlock Text="Confirmer le mot de passe" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="ConfirmPasswordBox" Height="40" Padding="10,0" FontSize="13" BorderBrush="#D1D5DB" BorderThickness="1" VerticalContentAlignment="Center" PasswordChanged="ConfirmPasswordBox_Changed" Margin="0,0,0,20"/>
                    <Button Height="42" Foreground="White" FontWeight="SemiBold" FontSize="13" BorderThickness="0" Cursor="Hand" Command="{Binding ResetCommand}" Margin="0,0,0,12">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#1a2e5a"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#15244a"/></Trigger>
                                                <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.6"/></Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Réinitialiser le mot de passe"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLoading}" Value="True"><Setter Property="Text" Value="Réinitialisation..."/></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                    <Button Height="42" Foreground="#1a2e5a" FontWeight="SemiBold" FontSize="13" Cursor="Hand" Command="{Binding BackToLoginCommand}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6" BorderBrush="#D1D5DB" BorderThickness="1">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#F9FAFB"/></Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="Retour à la connexion"/>
                    </Button>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>
