<Window x:Class="smartest_desktop.Views.ResetPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmarTest — Réinitialisation du mot de passe"
        Height="600" Width="900"
        MinHeight="500" MinWidth="700"
        ResizeMode="CanResize"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#f0f3f9">

	<Window.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary Source="/Views/Styles/AuthStyles.xaml"/>
			</ResourceDictionary.MergedDictionaries>
		</ResourceDictionary>
	</Window.Resources>

	<Grid Background="#f0f3f9">

		<ScrollViewer HorizontalAlignment="Center" VerticalAlignment="Center"
                      VerticalScrollBarVisibility="Auto" MaxHeight="780">
			<Border Style="{StaticResource MainCard}">
				<Border.Effect>
					<DropShadowEffect Color="#000000" Opacity="0.07"
                                      BlurRadius="24" ShadowDepth="3"/>
				</Border.Effect>

				<StackPanel>

					<!-- Brand -->
					<TextBlock Text="SmarTest" Style="{StaticResource BrandTitle}"/>
					<TextBlock Text="PLATEFORME D'ÉVALUATION" Style="{StaticResource BrandSub}"/>

					<!-- Badge + Titre -->
					<TextBlock Text="Nouveau mot de passe" FontFamily="Georgia" FontSize="20"
                               Foreground="#0f1e3d" HorizontalAlignment="Center"/>
					<Border Style="{StaticResource AccentLine}"/>

					<TextBlock Text="Choisissez un nouveau mot de passe sécurisé."
                               FontSize="12" Foreground="#6b7a99" HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

					<!-- Succès -->
					<Border Style="{StaticResource AlertSuccess}"
                            Visibility="{Binding HasSuccess, Converter={StaticResource BoolToVis}}">
						<TextBlock Text="{Binding SuccessMessage}" Foreground="#27500a"
                                   FontSize="12" TextWrapping="Wrap"/>
					</Border>

					<!-- Erreur -->
					<Border Style="{StaticResource AlertError}"
                            Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
						<TextBlock Text="{Binding ErrorMessage}" Foreground="#791f1f"
                                   FontSize="12" TextWrapping="Wrap"/>
					</Border>

					<!-- Code -->
					<TextBlock Text="Code de réinitialisation" Style="{StaticResource FieldLabel}"/>
					<TextBox Style="{StaticResource InputBox}"
                             Text="{Binding Token, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,4"/>
					<TextBlock Text="Copiez le code reçu par email"
                               FontSize="11" Foreground="#8899b8" Margin="0,0,0,12"/>

					<!-- Nouveau mot de passe -->
					<TextBlock Text="Nouveau mot de passe" Style="{StaticResource FieldLabel}"/>
					<PasswordBox x:Name="PasswordBox"
                                 Style="{StaticResource InputPassword}"
                                 PasswordChanged="PasswordBox_Changed"
                                 Margin="0,0,0,4"/>
					<TextBlock Text="Min. 8 car. · 1 majuscule · 1 chiffre · 1 spécial"
                               FontSize="11" Foreground="#8899b8" Margin="0,0,0,12"/>

					<!-- Confirmer -->
					<TextBlock Text="Confirmer le mot de passe" Style="{StaticResource FieldLabel}"/>
					<PasswordBox x:Name="ConfirmPasswordBox"
                                 Style="{StaticResource InputPassword}"
                                 PasswordChanged="ConfirmPasswordBox_Changed"
                                 Margin="0,0,0,20"/>

					<!-- Bouton Réinitialiser -->
					<Button Style="{StaticResource PrimaryBtn}"
                            Command="{Binding ResetCommand}"
                            Margin="0,0,0,10">
						<TextBlock>
							<TextBlock.Style>
								<Style TargetType="TextBlock">
									<Setter Property="Text" Value="Réinitialiser le mot de passe"/>
									<Style.Triggers>
										<DataTrigger Binding="{Binding IsLoading}" Value="True">
											<Setter Property="Text" Value="Réinitialisation..."/>
										</DataTrigger>
									</Style.Triggers>
								</Style>
							</TextBlock.Style>
						</TextBlock>
					</Button>

					<!-- Bouton Retour -->
					<Button Style="{StaticResource SecondaryBtn}"
                            Command="{Binding BackToLoginCommand}">
						<TextBlock Text="Retour à la connexion"/>
					</Button>

					<!-- Footer -->
					<TextBlock Text="SmarTest — ENSA Oujda" Style="{StaticResource FooterText}"/>

				</StackPanel>
			</Border>
		</ScrollViewer>
	</Grid>
</Window>
